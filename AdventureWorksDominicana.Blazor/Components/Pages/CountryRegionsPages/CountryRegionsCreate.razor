@page "/CountryRegions/Create";
@inject CountryRegionsService countryRegionsService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;

<EditForm Model="CountryRegion" FormName="crearCountryRegion" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <div class="container">
        <div class="card shadow-lg">
            <div class="card-header text-center">
                <h3>Crear Country Region</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label"><strong>C&oacute;digo de pa&iacute;s</strong></label>
                    <input class="form-control" type="text" maxlength="3" @bind-value="CountryRegion.CountryRegionCode" placeholder="Escriba el codigo del pais/region..." />
                    <ValidationMessage For="(() => CountryRegion.CountryRegionCode)" />
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Nombre del pa&iacute;s/regi&oacute;n</strong></label>
                    <input class="form-control" type="text" maxlength="50" @bind-value="CountryRegion.Name" placeholder="Escriba el nombre del pais/region..." />
                    <ValidationMessage For="(() => CountryRegion.Name)" />
                </div>
            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/CountryRegions/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>


@code {
    public CountryRegion CountryRegion { get; set; } = new CountryRegion();

    protected override async Task OnInitializedAsync()
    {
    }

    public async Task Guardar()
    {
        var countryRepetido = await countryRegionsService.Buscar(CountryRegion.CountryRegionCode);
        if (countryRepetido != null)
        {
            toastService.ShowError("El código " + CountryRegion.CountryRegionCode + " ya está en uso");
            return;
        }

        var nombreRepetido = await countryRegionsService.GetList(c => c.Name.Equals(CountryRegion.Name));
        if (nombreRepetido.Any())
        {
            toastService.ShowError("El nombre " + CountryRegion.Name + " ya está en uso");
            return;
        }

        CountryRegion.CountryRegionCode = CountryRegion.CountryRegionCode.ToUpper();
        CountryRegion.ModifiedDate = DateTime.Now;
        bool guardado = await countryRegionsService.Guardar(CountryRegion);
        if (guardado)
        {
            toastService.ShowSuccess("Country Region guardado exitosamente.");
            navigationManager.NavigateTo("/CountryRegions/Index");
        }
        else
        {
            toastService.ShowError("No se pudo guardar el country region correctamente.");
        }
    }
}
