@page "/CountryRegions/Index";
@attribute [Authorize(Roles = "Admin")]

@inject CountryRegionsService countryRegionsService;
@rendermode InteractiveServer

<div class="country-index-container">

    <div class="country-card">

        <!-- HEADER -->
        <div class="country-header">
            <div>
                <h3>Country Regions</h3>
                <span>Listado de regiones por país</span>
            </div>

            <a class="btn btn-primary bi bi-plus-square"
                   href="/CountryRegions/Create">
                Crear
            </a>
        </div>

        <!-- FILTROS -->
        <div class="country-filters">

            <div class="row">
                <div class="col-3"><label>Desde</label></div>
                <div class="col-3"><label>Hasta</label></div>
                <div class="col-3"><label>Filtro</label></div>
                <div class="col-3"><label>Buscar</label></div>
            </div>

            <div class="row pb-3">
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaDesde" />
                </div>

                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaHasta" />
                </div>

                <div class="col-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="">Seleccione...</option>
                        <option value="CountryRegionCode">Código</option>
                        <option value="Nombre">Nombre</option>
                    </select>
                </div>

                <div class="col-3">
                    <div class="input-group">
                        <input class="form-control" type="text" @bind-value="ValorFiltro" placeholder="Buscar..." />

                        <button class="btn btn-primary bi bi-search" type="button" @onclick="Filtrar"></button>
                        <button class="btn btn-outline-primary bi bi-arrow-clockwise" type="button" @onclick="Restablecer"></button>
                    </div>
                </div>
            </div>

        </div>

        <!-- TABLA -->
        <div class="country-table">

            <div class="table-responsive">
                <QuickGrid Class="table table-striped table-bordered table-hover"
                           Pagination="@pages"
                           Items="ListaCountryRegions.AsQueryable()"
                           ItemKey="@(s => s.CountryRegionCode)">

                    <PropertyColumn Property="@(s => s.CountryRegionCode)" Title="Código" Sortable="true" />
                    <PropertyColumn Property="@(s => s.Name)" Title="Nombre" Sortable="true" />

                    <TemplateColumn Class="text-center" Context="options" Title="Acción">
                        <a href="/CountryRegions/Edit/@options.CountryRegionCode"
                               class="btn btn-outline-primary btn-sm bi bi-pencil-square">
                            Modificar
                        </a>
                    </TemplateColumn>

                </QuickGrid>

                <Paginator State="@pages" />
            </div>

        </div>

    </div>

</div>

@code {
    public List<CountryRegion> ListaCountryRegions { get; set; } = new List<CountryRegion>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        ListaCountryRegions = await countryRegionsService.GetList(c => !c.CountryRegionCode.Equals(""));
        ListaCountryRegions = ListaCountryRegions.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<CountryRegion, bool>> criterio = c => !c.CountryRegionCode.Equals("");

        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value && c.ModifiedDate <= fechaHasta);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate <= fechaHasta);
        }
        if (Filtro != "" && ValorFiltro != "")
        {
            if (Filtro == "CountryRegionCode")
            {
                Console.WriteLine("Code");
                criterio = criterio.And(c => c.CountryRegionCode.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            if (Filtro == "Nombre")
            {
                Console.WriteLine("Name");
                criterio = criterio.And(c => c.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }
        ListaCountryRegions = await countryRegionsService.GetList(criterio);
        ListaCountryRegions = ListaCountryRegions.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
