@page "/Culture/Create"
@attribute [Authorize(Roles = "Admin")]

@inject NavigationManager navigationManager
@inject ToastService toastService
@inject CultureService cultureService
@rendermode InteractiveServer

<PageTitle>Crear Cultura</PageTitle>

<div class="culture-create-container">

    <!-- HEADER -->
    <div class="culture-create-header">
        <div>
            <h3>Crear Cultura</h3>
            <span>Registro de nuevas culturas en el sistema</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="culture-create-form">
        <EditForm Model="culture" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-globe"></i> Datos de la Cultura
                    </h5>

                    <!-- ID -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>ID de Cultura</strong>
                        </label>

                        <input class="form-control"
                               type="text"
                               maxlength="6"
                               @bind="culture.CultureId"
                               placeholder="Ej: es-DO" />

                        <ValidationMessage For="(() => culture.CultureId)" />
                    </div>

                    <!-- NOMBRE -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Nombre</strong>
                        </label>

                        <input class="form-control"
                               type="text"
                               maxlength="50"
                               @bind="culture.Name"
                               placeholder="Ej: Español (República Dominicana)" />

                        <ValidationMessage For="(() => culture.Name)" />
                    </div>

                    <!-- FECHA -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Fecha de Modificación</strong>
                        </label>

                        <input class="form-control"
                               value="@culture.ModifiedDate.ToString("dd/MM/yyyy")"
                               disabled />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensaje))
                    {
                        <div class="alert alert-danger mt-3">
                            @mensaje
                        </div>
                    }

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">

                    <a class="btn btn-secondary bi bi-arrow-left" href="/Culture/Index">
                        Volver
                    </a>

                    <button class="btn btn-primary bi bi-floppy" type="submit">
                        Guardar
                    </button>

                </div>
            </div>
        </EditForm>
    </div>

</div>

@code {
    public Culture culture { get; set; } = new Culture();
    private string mensaje = string.Empty;

    protected override void OnInitialized()
    {
        culture.ModifiedDate = DateTime.Now;
    }

    public async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(culture.CultureId))
        {
            toastService.ShowWarning("El ID de la Cultura es obligatorio.");
            return;
        }

        var isCultureDuplicated = await cultureService.GetList(c =>
            c.CultureId.ToLower() == culture.CultureId.ToLower() ||
            c.Name.ToLower() == culture.Name.ToLower()
        );

        if (isCultureDuplicated.Any())
        {
            mensaje = $"Ya existe una cultura registrada con ese ID ({culture.CultureId}) o Nombre ({culture.Name}).";
            return;
        }

        culture.ModifiedDate = DateTime.Now;

        try
        {
            bool guardado = await cultureService.Guardar(culture);
            if (guardado)
            {
                toastService.ShowSuccess("La cultura se ha guardado correctamente.");
                navigationManager.NavigateTo("/Culture/Index");
            }
            else
            {
                toastService.ShowError("Ha ocurrido un error inesperado al guardar la cultura.");
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }
}