@page "/Culture/Edit/{CultureId}"
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject CultureService cultureService
@rendermode InteractiveServer

<PageTitle>Editar Cultura</PageTitle>

<Toasts class="p-3" AutoHide="true" Delay="5000" Placement="ToastsPlacement.TopRight" />

@if (culture == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="culture" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <div class="container mt-4">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4 class="mb-0">Editar cultura</h4>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">ID de Cultura</label>
                        <InputText class="form-control" @bind-Value="culture.CultureId" readonly />
                        <ValidationMessage For="() => culture.CultureId" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre</label>
                        <InputText class="form-control" @bind-Value="culture.Name" maxlength="50" />
                        <ValidationMessage For="() => culture.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Última Modificación</label>
                        <InputDate class="form-control" @bind-Value="culture.ModifiedDate" readonly />
                        <ValidationMessage For="() => culture.ModifiedDate" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensaje))
                    {
                        <div class="alert alert-danger">
                            @mensaje
                        </div>
                    }
                </div>
                <div class="card-footer text-center">
                    <a class="btn btn-outline-secondary bi bi-arrow-left" href="/Culture/Index"> Volver</a>
                    <button type="submit" class="btn btn-outline-success bi bi-file-earmark"> Guardar</button>
                    <button type="button" class="btn btn-outline-danger bi bi-trash" @onclick="MostrarModalEliminar"> Eliminar</button>
                </div>
            </div>
        </div>
    </EditForm>

    @if (mostrarModal)
    {
        <div class="alert alert-danger mt-3">
            <p>¿Desea eliminar esta cultura?</p>
            <button class="btn btn-secondary me-2" @onclick="CerrarModalEliminar">
                Cancelar
            </button>
            <button class="btn btn-danger" @onclick="EliminarConfirmado">
                Si, eliminar
            </button>
        </div>
    }
}

@code {
    [Parameter]
    public string CultureId { get; set; } = string.Empty;

    private Culture? culture;
    private string mensaje = string.Empty;
    private bool mostrarModal = false;

    protected override async Task OnParametersSetAsync()
    {
        culture = await cultureService.Buscar(CultureId);
        if (culture == null)
        {
            mensaje = "Cultura no encontrada";
        }
    }

    private async Task Guardar()
    {
        if (culture == null) return;

        var isCultureDuplicated = await cultureService.GetList(c =>
            c.Name.ToLower() == culture.Name.ToLower() &&
            c.CultureId.ToLower() != culture.CultureId.ToLower()
        );

        if (isCultureDuplicated.Any())
        {
            mensaje = $"Ya existe otra cultura registrada con el Nombre ({culture.Name}).";
            return;
        }

        culture.ModifiedDate = DateTime.Now;

        try
        {
            if (await cultureService.Guardar(culture))
            {
                toastService.ShowSuccess($"Cultura {culture.Name} actualizada correctamente.");
                navigationManager.NavigateTo("/Culture/Index");
            }
            else
            {
                mensaje = "Ocurrió un error al intentar actualizar la cultura.";
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }

    private void MostrarModalEliminar()
    {
        mostrarModal = true;
    }

    private void CerrarModalEliminar()
    {
        mostrarModal = false;
    }

    private async Task EliminarConfirmado()
    {
        if (culture == null) return;

        try
        {
            if (await cultureService.Eliminar(culture.CultureId))
            {
                toastService.ShowSuccess("Cultura eliminada correctamente.");
                navigationManager.NavigateTo("/Culture/Index");
            }
            else
            {
                mensaje = "Ocurrió un error al intentar eliminar la cultura.";
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
        
        mostrarModal = false;
    }
}