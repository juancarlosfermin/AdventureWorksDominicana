@page "/Currency/Create"
@attribute [Authorize(Roles = "Admin")]

@rendermode InteractiveServer
@inject CurrencyService CurrencyService
@inject ToastService toast
@inject NavigationManager NavigationManager

<PageTitle>Crear Moneda</PageTitle>

<div class="product-container">

    <!-- HEADER -->
    <div class="product-header">
        <div>
            <h3>Crear Moneda</h3>
            <span>Registro de nuevas monedas en el sistema</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="product-form">
        <EditForm Model="currency" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-currency-dollar"></i> Información General
                    </h5>

                    <!-- CÓDIGO -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Código de Moneda</strong></label>
                        <InputText class="form-control"
                                   @bind-Value="currency.CurrencyCode"
                                   placeholder="Ej: DOP" />
                        <ValidationMessage For="@(() => currency.CurrencyCode)" />
                    </div>

                    <!-- NOMBRE -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <InputText class="form-control"
                                   @bind-Value="currency.Name"
                                   placeholder="Ej: Peso Dominicano" />
                        <ValidationMessage For="@(() => currency.Name)" />
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">

                    <a href="/Currency/Index" class="btn btn-secondary bi bi-arrow-left">
                        Volver
                    </a>

                    <button type="submit" class="btn btn-primary bi bi-floppy">
                        Guardar
                    </button>

                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private Currency currency = new Currency();

    private async Task Guardar()
    {
        if (!string.IsNullOrEmpty(currency.CurrencyCode))
        {
            currency.CurrencyCode = currency.CurrencyCode.ToUpper();
        }

        var guardo = await CurrencyService.Guardar(currency);

        if (guardo)
        {
            toast.ShowSuccess("Moneda guardada correctamente.");
            Volver();
        }
        else
        {
            toast.ShowError("Error al guardar la moneda. Verifique que el código no exista.");
        }
    }
    private void Volver() => NavigationManager.NavigateTo("/BillOfMaterial/Index");
}