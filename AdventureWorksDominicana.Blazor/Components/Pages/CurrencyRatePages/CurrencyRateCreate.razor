@page "/CurrencyRate/Create"
@attribute [Authorize(Roles = "Admin")]

@inject CurrencyRateService currencyRateService
@inject CurrencyService currencyService
@inject NavigationManager navigationManager
@inject ToastService toastService

@rendermode InteractiveServer

<PageTitle>Crear Tasa de Cambio</PageTitle>

<div class="currencyrate-form-container">

    <!-- HEADER -->
    <div class="currencyrate-form-header">
        <div>
            <h3>Crear Tasa de Cambio</h3>
            <span>Registro de nuevas tasas de cambio</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="currencyrate-form-body">

        <EditForm Model="tasa" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card">

                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-currency-exchange"></i> Información General
                    </h5>

                    <!-- FECHA -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Fecha de Tasa</strong></label>
                        <InputDate class="form-control" @bind-Value="tasa.CurrencyRateDate" />
                        <ValidationMessage For="() => tasa.CurrencyRateDate" />
                    </div>

                    <!-- MONEDAS -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Moneda Origen</strong></label>
                            <InputSelect class="form-select" @bind-Value="tasa.FromCurrencyCode">
                                <option value="">Seleccione una moneda...</option>
                                @foreach (var moneda in listaMonedas)
                                {
                                    <option value="@moneda.CurrencyCode">@moneda.CurrencyCode - @moneda.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => tasa.FromCurrencyCode" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Moneda Destino</strong></label>
                            <InputSelect class="form-select" @bind-Value="tasa.ToCurrencyCode">
                                <option value="">Seleccione una moneda...</option>
                                @foreach (var moneda in listaMonedas)
                                {
                                    <option value="@moneda.CurrencyCode">@moneda.CurrencyCode - @moneda.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => tasa.ToCurrencyCode" />
                        </div>
                    </div>

                    <!-- TASAS -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Tasa Promedio del Día</strong></label>
                            <InputNumber class="form-control" @bind-Value="tasa.AverageRate" />
                            <ValidationMessage For="() => tasa.AverageRate" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Tasa al Cierre del Día</strong></label>
                            <InputNumber class="form-control" @bind-Value="tasa.EndOfDayRate" />
                            <ValidationMessage For="() => tasa.EndOfDayRate" />
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensajeError))
                    {
                        <div class="alert alert-danger mt-3">@mensajeError</div>
                    }

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">

                    <a href="/CurrencyRate/Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy"></i> Guardar
                    </button>

                </div>

            </div>

        </EditForm>

    </div>
</div>

@code {
    private CurrencyRate tasa = new() { CurrencyRateDate = DateTime.Now };
    private List<Currency> listaMonedas = new();
    private string mensajeError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        listaMonedas = await currencyService.GetList(c => true);
    }

    private async Task Guardar()
    {
        tasa.ModifiedDate = DateTime.Now;
        mensajeError = string.Empty;

        try
        {
            if (await currencyRateService.Guardar(tasa))
            {
                toastService.ShowSuccess("Cambios guardados correctamente.");
                navigationManager.NavigateTo("/CurrencyRate/Index");
            }
            else
            {
                mensajeError = "No se pudo guardar el registro.";
            }
        }
        catch (Exception ex)
        {
            string errorReal = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            mensajeError = $"La base de datos rechazó el registro. Detalle: {errorReal}";
        }
    }
}