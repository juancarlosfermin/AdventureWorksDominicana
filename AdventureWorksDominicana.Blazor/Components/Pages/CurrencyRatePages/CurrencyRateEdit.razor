@page "/CurrencyRate/Edit/{Id:int}"
@attribute [Authorize(Roles = "Admin")]

@inject CurrencyRateService currencyRateService
@inject CurrencyService currencyService
@inject NavigationManager navigationManager
@inject ToastService toastService


@rendermode InteractiveServer

<PageTitle>Editar Tasa de Cambio</PageTitle>

@if (tasa == null)
{
    <div class="currencyrate-form-container">
        <p>Cargando información...</p>
    </div>
}
else
{
    <div class="currencyrate-form-container">

        <!-- HEADER -->
        <div class="currencyrate-form-header">
            <div>
                <h3>Modificar Tasa de Cambio</h3>
                <span>Edición de tasa de cambio existente</span>
            </div>
        </div>

        <!-- FORM -->
        <div class="currencyrate-form-body">

            <EditForm Model="tasa" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="card">

                    <div class="card-body">

                        <!-- SECCIÓN -->
                        <h5 class="section-title">
                            <i class="bi bi-pencil-square"></i> Información General
                        </h5>

                        <!-- ID -->
                        <div class="mb-3">
                            <label class="form-label"><strong>ID Tasa</strong></label>
                            <InputNumber class="form-control"
                                         @bind-Value="tasa.CurrencyRateId"
                                         readonly />
                        </div>

                        <!-- FECHA -->
                        <div class="mb-3">
                            <label class="form-label"><strong>Fecha de Tasa</strong></label>
                            <InputDate class="form-control"
                                       @bind-Value="tasa.CurrencyRateDate" />
                            <ValidationMessage For="() => tasa.CurrencyRateDate" />
                        </div>

                        <!-- MONEDAS -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>Moneda Origen</strong></label>
                                <InputSelect class="form-select"
                                             @bind-Value="tasa.FromCurrencyCode">
                                    <option value="">Seleccione una moneda...</option>
                                    @foreach (var moneda in listaMonedas)
                                    {
                                        <option value="@moneda.CurrencyCode">@moneda.CurrencyCode - @moneda.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => tasa.FromCurrencyCode" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>Moneda Destino</strong></label>
                                <InputSelect class="form-select"
                                             @bind-Value="tasa.ToCurrencyCode">
                                    <option value="">Seleccione una moneda...</option>
                                    @foreach (var moneda in listaMonedas)
                                    {
                                        <option value="@moneda.CurrencyCode">@moneda.CurrencyCode - @moneda.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => tasa.ToCurrencyCode" />
                            </div>
                        </div>

                        <!-- TASAS -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>Tasa Promedio del Día</strong></label>
                                <InputNumber class="form-control"
                                             @bind-Value="tasa.AverageRate" />
                                <ValidationMessage For="() => tasa.AverageRate" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>Tasa al Cierre del Día</strong></label>
                                <InputNumber class="form-control"
                                             @bind-Value="tasa.EndOfDayRate" />
                                <ValidationMessage For="() => tasa.EndOfDayRate" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(mensajeError))
                        {
                            <div class="alert alert-danger mt-3">@mensajeError</div>
                        }

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer text-center">

                        <a href="/CurrencyRate/Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy"></i> Modificar
                        </button>

                        <button type="button"
                                class="btn btn-danger"
                                @onclick="() => mostrarModal = true">
                            <i class="bi bi-trash"></i> Eliminar
                        </button>

                    </div>

                </div>

            </EditForm>

        </div>

        <!-- MODAL SIMPLE -->
        @if (mostrarModal)
        {
            <div class="currencyrate-delete-alert">
                <div class="alert alert-danger shadow-sm">
                    <p class="fw-bold">¿Desea eliminar este registro?</p>

                    <button class="btn btn-secondary me-2"
                            @onclick="() => mostrarModal = false">
                        Cancelar
                    </button>

                    <button class="btn btn-danger"
                            @onclick="EliminarConfirmado">
                        Sí, eliminar definitivamente
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private CurrencyRate? tasa;
    private List<Currency> listaMonedas = new();
    private string mensajeError = string.Empty;
    private bool mostrarModal = false;

    protected override async Task OnParametersSetAsync()
    {
        tasa = await currencyRateService.Buscar(Id);
        if (tasa == null)
        {
            mensajeError = "No se encontró la tasa de cambio.";
        }
        else
        {
            listaMonedas = await currencyService.GetList(c => true);
        }
    }

    private async Task Guardar()
    {
        if (tasa == null) return;
        tasa.ModifiedDate = DateTime.Now;
        mensajeError = string.Empty;

        try
        {
            if (await currencyRateService.Guardar(tasa))
            {
                toastService.ShowSuccess("Cambios guardados correctamente.");
                navigationManager.NavigateTo("/CurrencyRate/Index");
            }
        }
        catch (Exception ex)
        {
            string errorReal = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            mensajeError = $"Error al actualizar. Detalle: {errorReal}";
        }
    }

    private async Task EliminarConfirmado()
    {
        if (tasa == null) return;

        if (await currencyRateService.Eliminar(tasa.CurrencyRateId))
        {
            navigationManager.NavigateTo("/CurrencyRate/Index");
        }
        else
        {
            mensajeError = "No se pudo eliminar el registro.";
            mostrarModal = false;
        }
    }
}