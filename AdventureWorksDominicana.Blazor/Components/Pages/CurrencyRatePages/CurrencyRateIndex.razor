@page "/CurrencyRate/Index"
@attribute [Authorize(Roles = "Admin")]

@inject CurrencyRateService currencyService
@inject ToastService toastService
@rendermode InteractiveServer

<PageTitle>Tasas de Cambio</PageTitle>

<div class="currencyrate-container">

    <!-- HEADER -->
    <div class="currencyrate-header">
        <div>
            <h3>Registro de Tasas de Cambio</h3>
            <span>Gestión y consulta de tasas de cambio</span>
        </div>

        <a class="btn btn-primary" href="/CurrencyRate/Create">
            <i class="bi bi-plus-square"></i> Crear
        </a>
    </div>

    <!-- FILTROS -->
    <div class="currencyrate-filters">
        <div class="row g-3">

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="date" @bind="Desde" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="date" @bind="Hasta" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Filtrar por</label>
                <select class="form-select" @bind="Filtros">
                    <option value="">Seleccione una opción</option>
                    <option value="Id">Id</option>
                    <option value="From">Moneda Origen</option>
                    <option value="To">Moneda Destino</option>
                </select>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control" type="text" placeholder="Buscar..." @bind="ValorFiltro" />
                    <button class="btn btn-outline-primary" @onclick="Buscar">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- TABLA -->
    <div class="currencyrate-table">

        <div class="table-responsive">

            <QuickGrid Items="listaTasas.AsQueryable()" Class="table table-hover" Pagination="@pages">

                <PropertyColumn Property="@(c => c.CurrencyRateId)" Title="ID" />
                <PropertyColumn Property="@(c => c.CurrencyRateDate.ToString("dd/MM/yyyy"))" Title="Fecha Tasa" />
                <PropertyColumn Property="@(c => c.FromCurrencyCode)" Title="Origen" />
                <PropertyColumn Property="@(c => c.ToCurrencyCode)" Title="Destino" />
                <PropertyColumn Property="@(c => c.AverageRate)" Title="Tasa Promedio" />

                <TemplateColumn Title="Acciones">
                    <a class="btn btn-sm btn-outline-primary" href="/CurrencyRate/Edit/@context.CurrencyRateId">
                        <i class="bi bi-pencil"></i> Modificar
                    </a>
                </TemplateColumn>

            </QuickGrid>

            <Paginator State="@pages" />
        </div>

    </div>

</div>

@code {
    private List<CurrencyRate> listaTasas = new();
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };

    private DateTime? Desde;
    private DateTime? Hasta;
    private string Filtros = "";
    private string ValorFiltro = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        listaTasas = await currencyService.GetList(c => true);
    }

    private async Task Buscar()
    {
        listaTasas = await currencyService.GetList(c =>
            (!Desde.HasValue || c.CurrencyRateDate >= Desde.Value) &&
            (!Hasta.HasValue || c.CurrencyRateDate <= Hasta.Value) &&
            (string.IsNullOrEmpty(ValorFiltro) ||
                (Filtros == "Id" && c.CurrencyRateId.ToString() == ValorFiltro) ||
                (Filtros == "From" && c.FromCurrencyCode.Contains(ValorFiltro)) ||
                (Filtros == "To" && c.ToCurrencyCode.Contains(ValorFiltro))
            ));
    }

    private async Task Restablecer()
    {
        Desde = null;
        Hasta = null;
        Filtros = "";
        ValorFiltro = "";
        await CargarDatos();
    }
}