@page "/Department/Create"
@attribute [Authorize(Roles = "Admin,HRManager")]

@inject DepartmentService departmentService
@inject ToastService toastService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<PageTitle>Crear Departamento</PageTitle>

<EditForm Model="Department" FormName="crearDepartamento" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container mb-5">
        <div class="card shadow-lg">
            <div class="card-header text-center bg-light">
                <h4 class="card-title">Crear Departamento</h4>
            </div>
            <div class="card-body bg-light">
                
                @if (!string.IsNullOrWhiteSpace(mensajeError))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensajeError
                    </div>
                }

                <h5 class="mt-2">Datos del Departamento</h5>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Nombre Departamento:</strong></label>
                        <InputText class="form-control" maxlength="50" @bind-Value="Department.Name" placeholder="Ej: Ventas" />
                        <ValidationMessage For="(() => Department.Name)" class="text-danger" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Nombre del Grupo:</strong></label>
                        <InputText class="form-control" maxlength="50" @bind-Value="Department.GroupName" placeholder="Ej: Comercial" />
                        <ValidationMessage For="(() => Department.GroupName)" class="text-danger" />
                    </div>
                </div>

            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/Department/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public Department Department { get; set; } = new Department();
    private string mensajeError = string.Empty;

    protected override void OnInitialized()
    {
        // Agrego la fecha de modificacion inicial por defecto
        Department.ModifiedDate = DateTime.Now;
    }

    public async Task Guardar()
    {
        mensajeError = string.Empty;

        // Valido que los campos no vengan vacios (aunque los DataAnnotations deberian atraparlo, por si acaso)
        if (string.IsNullOrWhiteSpace(Department.Name) || string.IsNullOrWhiteSpace(Department.GroupName))
        {
            mensajeError = "Debe completar todos los campos obligatorios.";
            return;
        }

        // Busco si ya existe un departamento con ese nombre o en ese mismo grupo para evitar duplicados
        var isDepartmentDuplicated = await departmentService.GetList(d =>
            (d.Name.ToLower() == Department.Name.ToLower() || d.GroupName.ToLower() == Department.GroupName.ToLower())
            && d.DepartmentId != Department.DepartmentId);
            
        if (isDepartmentDuplicated.Any())
        {
            mensajeError = $"Ya existe un departamento registrado con el nombre '{Department.Name}' o en el grupo '{Department.GroupName}'.";
            return;
        }
        
        // Actualizo la fecha de modificacion antes de guardar
        Department.ModifiedDate = DateTime.Now;

        // Mando a ejecutar la accion en el servicio
        bool creado = await departmentService.Guardar(Department);
        
        if (creado)
        {
            toastService.ShowSuccess($"El departamento '{Department.Name}' se ha guardado correctamente.");
            navigationManager.NavigateTo("/Department/Index");
        }
        else
        {
            mensajeError = "Ha ocurrido un error inesperado al intentar guardar en la base de datos.";
        }
    }
}