@page "/Department/Edit/{DepartmentId:int}"
@attribute [Authorize(Roles = "Admin,HRManager")]

@inject DepartmentService departmentService
@inject ToastService toastService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<PageTitle>Editar Departamento</PageTitle>

<EditForm Model="Department" FormName="editarDepartamento" OnValidSubmit="Modificar">
    <DataAnnotationsValidator />

    <div class="container mb-5">
        <div class="card shadow-lg">
            <div class="card-header text-center bg-light">
                <h4 class="card-title">Editar Departamento</h4>
            </div>
            
            <div class="card-body bg-light">
                
                @if (!string.IsNullOrWhiteSpace(mensajeError))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensajeError
                    </div>
                }

                <h5 class="mt-2">Datos del Departamento</h5>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Nombre Departamento:</strong></label>
                        <InputText class="form-control" maxlength="50" @bind-Value="Department.Name" placeholder="Ej: Ventas" />
                        <ValidationMessage For="(() => Department.Name)" class="text-danger" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Nombre del Grupo:</strong></label>
                        <InputText class="form-control" maxlength="50" @bind-Value="Department.GroupName" placeholder="Ej: Comercial" />
                        <ValidationMessage For="(() => Department.GroupName)" class="text-danger" />
                    </div>
                </div>

            </div>
            
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/Department/Index"> Volver</a>
                <button type="button" class="btn btn-danger bi bi-trash3 mx-2" @onclick="Eliminar"> Eliminar</button>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Modificar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    [Parameter]
    public int DepartmentId { get; set; }
    
    public Department Department { get; set; } = new Department();
    private string mensajeError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Esto busca el departamento cuando carga la pagina
        var deptoEncontrado = await departmentService.Buscar((short)DepartmentId);
        
        if (deptoEncontrado != null)
        {
            Department = deptoEncontrado;
        }
        else
        {
            toastService.ShowError("No se pudo encontrar el departamento seleccionado.");
            navigationManager.NavigateTo("/Department/Index");
        }
    }

    private async Task Eliminar()
    {
        // Mando a eliminar pasando el ID y casteo a short
        var eliminado = await departmentService.Eliminar((short)DepartmentId);
        
        if (eliminado)
        {
            toastService.ShowSuccess($"El departamento '{Department.Name}' se eliminó correctamente.");
            navigationManager.NavigateTo("/Department/Index");
        }
        else
        {
            mensajeError = "No se pudo eliminar el departamento. Verifique que no tenga empleados asignados.";
        }
    }

    private async Task Modificar()
    {
        mensajeError = string.Empty;

        // Agrego validacion extra por si acaso el DataAnnotations se pasa
        if (string.IsNullOrWhiteSpace(Department.Name) || string.IsNullOrWhiteSpace(Department.GroupName))
        {
            mensajeError = "Debe completar todos los campos obligatorios.";
            return;
        }

        // Esto valida que no se dupliquen los nombres convirtiendo a minusculas para comparar mejor
        var isDepartmentDuplicated = await departmentService.GetList(d =>
            (d.Name.ToLower() == Department.Name.ToLower() || d.GroupName.ToLower() == Department.GroupName.ToLower())
            && d.DepartmentId != Department.DepartmentId);
            
        if (isDepartmentDuplicated.Any())
        {
            mensajeError = $"Ya existe otro departamento con el nombre '{Department.Name}' o en el grupo '{Department.GroupName}'.";
            return;
        }
        
        // Actualizo la fecha de modificacion
        Department.ModifiedDate = DateTime.Now;

        // Mando a ejecutar el guardado en el servicio
        var modificado = await departmentService.Guardar(Department);
        
        if (modificado)
        {
            toastService.ShowSuccess($"El departamento '{Department.Name}' se actualizó correctamente.");
            navigationManager.NavigateTo("/Department/Index");
        }
        else
        {
            mensajeError = "Ha ocurrido un error inesperado al intentar actualizar la base de datos.";
        }
    }
}