@page "/PaymentsMethods"
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using AdventureWorksDominicana.Data.Models
@inject AuthenticationStateProvider authenticationStateProvider
@inject ToastService toastService
@inject PersonService personService
@rendermode InteractiveServer

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">M&eacute;todos de Pago</h2>
            <p class="text-muted">Gestiona tus tarjetas de cr&eacute;dito registradas.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title fw-semibold mb-0">Mis Tarjetas</h5>
                        @if (NuevaTarjeta == null)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AgregarNuevaTarjeta">
                                + Agregar Tarjeta
                            </button>
                        }
                    </div>

                    @if (TarjetasExistentes.Any())
                    {
                        <div class="list-group mb-4">
                            @foreach (var pcc in TarjetasExistentes)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-credit-card-fill fs-3 text-secondary me-3"></i>
                                        <div>
                                            <h6 class="mb-0 fw-medium">@pcc.CreditCard.CardType</h6>
                                            <small class="text-muted">
                                                Termina en •••• @ObtenerUltimosDigitos(pcc.CreditCard.CardNumber) | Vence: @pcc.CreditCard.ExpMonth.ToString("D2")/@pcc.CreditCard.ExpYear
                                            </small>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => EliminarTarjetaExistente(pcc)">
                                        Eliminar
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border text-center text-muted mb-4" role="alert">
                            No tienes tarjetas guardadas.
                        </div>
                    }

                    @if (NuevaTarjeta != null)
                    {
                        <hr class="my-4" />
                        
                        <EditForm Model="NuevaTarjeta" OnValidSubmit="GuardarCambios">
                            <DataAnnotationsValidator />

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-semibold text-primary mb-0">Registrar Nueva Tarjeta</h6>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="CancelarNuevaTarjeta">
                                        Cancelar
                                    </button>
                                    <button type="submit" class="btn btn-sm btn-primary shadow-sm bi bi-floppy">
                                        Guardar Tarjeta
                                    </button>
                                </div>
                            </div>
                            
                            <div class="row g-3 p-3 border rounded bg-light">
                                <div class="col-md-6">
                                    <label class="form-label small fw-medium">Tipo de Tarjeta</label>
                                    <select class="form-select" @bind="NuevaTarjeta.CardType">
                                        <option value="" disabled selected>Seleccione...</option>
                                        <option value="Visa">Visa</option>
                                        <option value="MasterCard">Master-Card</option>
                                    </select>
                                    <ValidationMessage For="@(() => NuevaTarjeta.CardType)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-medium">N&uacute;mero de Tarjeta</label>
                                    <input type="text" class="form-control" @bind="NuevaTarjeta.CardNumber" placeholder="Ej: 1111-2222-3333-4444" />
                                    <ValidationMessage For="@(() => NuevaTarjeta.CardNumber)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-medium">Mes de Expiraci&oacute;n</label>
                                    <input type="number" class="form-control" @bind="NuevaTarjeta.ExpMonth" placeholder="MM" />
                                    <ValidationMessage For="@(() => NuevaTarjeta.ExpMonth)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-medium">Año de Expiraci&oacute;n</label>
                                    <input type="number" class="form-control" @bind="NuevaTarjeta.ExpYear" placeholder="YYYY" />
                                    <ValidationMessage For="@(() => NuevaTarjeta.ExpYear)" class="text-danger small" />
                                </div>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }
    private string UserId { get; set; } = string.Empty;
    private int _businessEntityId = 0;

    private List<PersonCreditCard> TarjetasExistentes { get; set; } = new();

    private CreditCard? NuevaTarjeta { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;

        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
            var idClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(idClaim) && !string.IsNullOrEmpty(UserEmail))
            {
                UserId = idClaim;
                await CargarTarjetasDelUsuario(UserEmail);
            }
            else
            {
                toastService.ShowError("No se pudo identificar al usuario.");
            }
        }
    }

    private async Task CargarTarjetasDelUsuario(string email)
    {
        var personaDB = await personService.BuscarPorEmailCompleto(email);

        if (personaDB != null)
        {
            _businessEntityId = personaDB.BusinessEntityId;
            TarjetasExistentes = await personService.ObtenerTarjetasPorPersonaId(_businessEntityId);
        }
        else
        {
            toastService.ShowWarning("No encontramos tu perfil en el sistema.");
        }
    }

    private void AgregarNuevaTarjeta()
    {
        NuevaTarjeta = new CreditCard
        {

        };
    }

    private void CancelarNuevaTarjeta()
    {
        NuevaTarjeta = null;
    }

    private async Task EliminarTarjetaExistente(PersonCreditCard pcc)
    {
        var exito = await personService.EliminarTarjetaDePersona(_businessEntityId, pcc.CreditCardId);
        
        if (exito)
        {
            TarjetasExistentes.Remove(pcc);
            toastService.ShowSuccess("Tarjeta eliminada correctamente.");
        }
        else
        {
            toastService.ShowError("No se pudo eliminar la tarjeta.");
        }
    }

    private async Task GuardarCambios()
    {
        if (_businessEntityId == 0)
        {
            toastService.ShowWarning("Aún no tienes un perfil base.");
            return;
        }

        if (NuevaTarjeta == null) return;

        var exito = await personService.AgregarTarjetaAPersona(_businessEntityId, NuevaTarjeta);

        if (exito)
        {
            toastService.ShowSuccess("Tu tarjeta ha sido guardada correctamente.");
            NuevaTarjeta = null; // Limpio el formulario tras guardar
            
            // Recargo la lista
            TarjetasExistentes = await personService.ObtenerTarjetasPorPersonaId(_businessEntityId);
        }
        else
        {
            toastService.ShowError("Ocurrió un error al intentar guardar la tarjeta.");
        }
    }

    private string ObtenerUltimosDigitos(string numeroTarjeta)
    {
        if (string.IsNullOrWhiteSpace(numeroTarjeta)) return "0000";
        var cleanNumber = numeroTarjeta.Replace(" ", "").Replace("-", "");
        if (cleanNumber.Length <= 4) return cleanNumber;
        return cleanNumber.Substring(cleanNumber.Length - 4);
    }
}