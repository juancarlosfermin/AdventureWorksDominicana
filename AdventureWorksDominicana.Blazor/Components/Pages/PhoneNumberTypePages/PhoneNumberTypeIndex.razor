@page "/PhoneNumberType/Index";

@inject PhoneNumberTypeService phoneNumberTypeService;
@rendermode InteractiveServer

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between">
            <h4>Phone Number Types</h4>
            <a class="btn btn-primary bi bi-plus-square" href="/PhoneNumberType/Create"> Crear</a>
        </div>
        <div class="card-body">
            
            @* Encabezados *@
            <div class="row">
                <div class="col-3">
                    <label>Desde:</label>
                </div>
                <div class="col-3">
                    <label>Hasta:</label>
                </div>
                <div class="col-3">
                    <label>Filtro:</label>
                </div>
                <div class="col-3">
                    <label>Buscar:</label>
                </div>
            </div>

            @* Inputs *@
            <div class="row pb-3">
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaDesde" />
                </div>
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaHasta" />
                </div>
                <div class="col-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="" disabled selected hidden>Seleccione un filtro...</option>
                        <option value="Nombre">Nombre</option>
                    </select>
                </div>
                <div class="col-3">
                    <div class="input-group">
                        <input class="form-control" type="text" @bind-value="ValorFiltro" placeholder="Buscar..." />
                        <button class="btn btn-primary bi bi-search" type="button" @onclick="Filtrar"></button>
                        <button class="btn btn-outline-primary bi bi-arrow-clockwise" type="button" @onclick="Restablecer"></button>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <QuickGrid Class="table table-striped table-bordered table-hover" Pagination="@pages" Items="ListaPhoneNumberType.AsQueryable()" ItemKey="@(e => e.PhoneNumberTypeId)">
                    <PropertyColumn Property="@(s => s.PhoneNumberTypeId)" Sortable="true" Title="Id"></PropertyColumn>
                    <PropertyColumn Property="@(s => s.Name)" Sortable="true" Title="Nombre"></PropertyColumn>
                    <TemplateColumn Class="text-center" Context="options" Title="Acci&oacute;n">
                        <a href="/PhoneNumberType/Edit/@options.PhoneNumberTypeId" class="btn btn-outline-primary bi bi-pencil-square"> Modificar</a>
                    </TemplateColumn>
                </QuickGrid>
            </div>
            @*Pagination*@
            <Paginator State="@pages" />
        </div>
    </div>
</div>

@code {
    public List<PhoneNumberType> ListaPhoneNumberType { get; set; } = new List<PhoneNumberType>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        ListaPhoneNumberType = await phoneNumberTypeService.GetList(p => p.PhoneNumberTypeId > 0);
        ListaPhoneNumberType = ListaPhoneNumberType.OrderByDescending(p => p.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<PhoneNumberType, bool>> criterio = p => p.PhoneNumberTypeId > 0;

        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value && c.ModifiedDate <= fechaHasta);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(c => c.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(c => c.ModifiedDate <= fechaHasta);
        }
        if (Filtro != "" && ValorFiltro != "")
        {
            if (Filtro == "Nombre")
            {
                criterio = criterio.And(p => p.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }
        ListaPhoneNumberType = await phoneNumberTypeService.GetList(criterio);
        ListaPhoneNumberType = ListaPhoneNumberType.OrderByDescending(p => p.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
