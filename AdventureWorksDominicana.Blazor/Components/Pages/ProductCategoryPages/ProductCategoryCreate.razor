@page "/ProductCategory/Create"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductCategoryService categoryService

@rendermode InteractiveServer


<PageTitle>Crear Categoría de Producto</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="5000" Placement="ToastsPlacement.TopRight" />

<div class="category-form-container">

    <!-- HEADER -->
    <div class="category-form-header">
        <div>
            <h3>Crear Categoría</h3>
            <span>Gestión de categorías y subcategorías</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="category-form">

        <EditForm Model="categoria" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN GENERAL -->
                    <h5 class="section-title">
                        <i class="bi bi-folder"></i> Información General
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre de Categoría</strong></label>
                        <InputText class="form-control"
                                   @bind-Value="categoria.Name"
                                   placeholder="Ej: Bicicletas, Accesorios..." />
                        <ValidationMessage For="() => categoria.Name" />
                    </div>

                    <!-- SECCIÓN DETALLE -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-diagram-3"></i> Subcategorías
                    </h5>

                    <!-- INPUT NUEVO -->
                    <div class="row g-2 mb-3 align-items-end">
                        <div class="col-md-10">
                            <label class="form-label"><strong>Nueva Subcategoría</strong></label>
                            <InputText class="form-control"
                                       @bind-Value="NuevaSubcategoriaNombre"
                                       placeholder="Nueva subcategoría..." />
                        </div>

                        <div class="col-md-2">
                            <button type="button"
                                    class="btn btn-primary w-100 bi bi-plus"
                                    @onclick="AgregarDetalle">
                                Agregar
                            </button>
                        </div>
                    </div>

                    <!-- TABLA DETALLE -->
                    <div class="category-detail-table">

                        <QuickGrid Items="categoria.ProductSubcategories.AsQueryable()"
                                   Class="table table-hover">

                            <PropertyColumn Property="@(d => d.Name)"
                                            Title="Subcategoría" />

                            <PropertyColumn Property="@(d => d.ModifiedDate.ToString("dd/MM/yyyy HH:mm"))"
                                            Title="Fecha Agregado" />

                            <TemplateColumn Title="Acción" Class="text-center" Context="category">
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger bi bi-trash"
                                        @onclick="(() => RemoverDetalle(category))">
                                    Eliminar
                                </button>
                            </TemplateColumn>

                        </QuickGrid>

                    </div>

                    <!-- TOTAL -->
                    <div class="mt-3 fw-bold category-total">
                        Total Subcategorías: @categoria.ProductSubcategories.Count
                    </div>

                    <!-- MENSAJE -->
                    @if (!string.IsNullOrWhiteSpace(mensaje))
                    {
                        <div class="alert alert-danger mt-3">
                            @mensaje
                        </div>
                    }

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">

                    <a class="btn btn-secondary bi bi-arrow-left"
                           href="/ProductCategory/Index">
                        Volver
                    </a>

                    <button type="submit"
                            class="btn btn-primary bi bi-floppy">
                        Guardar
                    </button>

                </div>
            </div>

        </EditForm>

    </div>
</div>

@code {
    private ProductCategory categoria { get; set; } = new() { ProductSubcategories = new List<ProductSubcategory>() };
    private string NuevaSubcategoriaNombre = string.Empty;
    private string mensaje = string.Empty;

    private void AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(NuevaSubcategoriaNombre))
        {
            mensaje = "Debe escribir un nombre para la subcategoría";
            return;
        }

        if (categoria.ProductSubcategories.Any(x => x.Name.Equals(NuevaSubcategoriaNombre, StringComparison.OrdinalIgnoreCase)))
        {
            mensaje = "Esta subcategoría ya está en la lista.";
            return;
        }

        categoria.ProductSubcategories.Add(new ProductSubcategory
        {
            Name = NuevaSubcategoriaNombre,
            ModifiedDate = DateTime.Now
        });

        toastService.ShowSuccess("Detalle agregado correctamente.");
        NuevaSubcategoriaNombre = string.Empty;
        mensaje = string.Empty;
    }

    private void RemoverDetalle(ProductSubcategory det)
    {
        categoria.ProductSubcategories.Remove(det);
        toastService.ShowWarning("Detalle agregado a borradores.");
    }

    private async Task Guardar()
    {
        if (!categoria.ProductSubcategories.Any())
        {
            mensaje = "Debes agregar al menos un detalle";
            return;
        }

        try
        {
            if (await categoryService.Guardar(categoria))
            {
                navigationManager.NavigateTo("/ProductCategory/Index");
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }
}