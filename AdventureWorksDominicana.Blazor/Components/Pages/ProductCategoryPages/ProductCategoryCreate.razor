@page "/ProductCategory/Create"
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductCategoryService categoryService

@rendermode InteractiveServer


<PageTitle>Crear Categoría de Producto</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="5000" Placement="ToastsPlacement.TopRight" />

<EditForm Model="categoria" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container mt-4">
        <div class="card shadow-lg">
            <div class="card-header">
                <h4 class="mb-0">Registro de Categorías de Producto</h4>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">ID Categoría</label>
                    <InputNumber class="form-control" @bind-Value="categoria.ProductCategoryId" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre de Categoría</label>
                    <InputText class="form-control" @bind-Value="categoria.Name" placeholder="Ej: Bicicletas, Accesorios..." />
                    <ValidationMessage For="() => categoria.Name" />
                </div>

                <div class="border border-success p-3 mb-3">
                    <h3 class="mb-3">Detalle de Subcategorías</h3>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <InputText class="form-control" @bind-Value="NuevaSubcategoriaNombre" placeholder="Nueva subcategoría..." />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-primary bi bi-plus" @onclick="AgregarDetalle"> Agregar</button>
                        </div>
                    </div>

                    <QuickGrid Items="categoria.ProductSubcategories.AsQueryable()" Class="table table-striped table-bordered table-hover">
                        <PropertyColumn Property="@(d => d.Name)" Title="Subcategoría" />
                        <PropertyColumn Property="@(d => d.ModifiedDate.ToString("dd/MM/yyyy HH:mm"))" Title="Fecha Agregado" />
                        <TemplateColumn>
                            <ChildContent Context="det">
                                <button type="button" class="btn btn-outline-dark btn-sm bi bi-trash" @onclick="(() => RemoverDetalle(det))"> Eliminar</button>
                            </ChildContent>
                        </TemplateColumn>
                    </QuickGrid>
                </div>

                <div class="mt-3 fw-bold">
                    Total Subcategorías: @categoria.ProductSubcategories.Count
                </div>

                @if (!string.IsNullOrWhiteSpace(mensaje))
                {
                    <div class="alert alert-danger">
                        @mensaje
                    </div>
                }
            </div>

            <div class="card-footer text-center">
                <a class="btn btn-outline-secondary bi bi-arrow-left" href="/ProductCategory/Index"> Volver</a>
                <button type="submit" class="btn btn-outline-success bi bi-file-earmark"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private ProductCategory categoria { get; set; } = new() { ProductSubcategories = new List<ProductSubcategory>() };
    private string NuevaSubcategoriaNombre = string.Empty;
    private string mensaje = string.Empty;

    private void AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(NuevaSubcategoriaNombre))
        {
            mensaje = "Debe escribir un nombre para la subcategoría";
            return;
        }

        if (categoria.ProductSubcategories.Any(x => x.Name.Equals(NuevaSubcategoriaNombre, StringComparison.OrdinalIgnoreCase)))
        {
            mensaje = "Esta subcategoría ya está en la lista.";
            return;
        }

        categoria.ProductSubcategories.Add(new ProductSubcategory
        {
            Name = NuevaSubcategoriaNombre,
            ModifiedDate = DateTime.Now,
            Rowguid = Guid.NewGuid()
        });

        toastService.ShowSuccess("Detalle agregado correctamente.");
        NuevaSubcategoriaNombre = string.Empty;
        mensaje = string.Empty;
    }

    private void RemoverDetalle(ProductSubcategory det)
    {
        categoria.ProductSubcategories.Remove(det);
        toastService.ShowWarning("Detalle agregado a borradores.");
    }

    private async Task Guardar()
    {
        if (!categoria.ProductSubcategories.Any())
        {
            mensaje = "Debes agregar al menos un detalle";
            return;
        }

        categoria.ModifiedDate = DateTime.Now;
        categoria.Rowguid = Guid.NewGuid();

        try
        {
            if (await categoryService.Guardar(categoria))
            {
                navigationManager.NavigateTo("/ProductCategory/Index");
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }
}