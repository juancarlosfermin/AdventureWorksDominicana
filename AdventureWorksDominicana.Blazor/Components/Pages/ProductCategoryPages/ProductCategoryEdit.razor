@page "/ProductCategory/Edit/{Id:int}"
@attribute [Authorize(Roles = "Admin, ProductionManager")]


@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductCategoryService categoryService

@rendermode InteractiveServer

<PageTitle>Editar Categoría</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="5000" Placement="ToastsPlacement.TopRight" />

@if (categoria == null)
{
    <div class="category-form-container">
        <p>Cargando...</p>
    </div>
}
else
{
    <div class="category-form-container">

        <!-- HEADER -->
        <div class="category-form-header">
            <div>
                <h3>Editar Categoría</h3>
                <span>Asignación y gestión de subcategorías</span>
            </div>
        </div>

        <!-- FORM -->
        <div class="category-form">

            <EditForm Model="categoria" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="card shadow-lg">
                    <div class="card-body">

                        <!-- SECCIÓN GENERAL -->
                        <h5 class="section-title">
                            <i class="bi bi-folder"></i> Información General
                        </h5>

                        <div class="mb-3">
                            <label class="form-label"><strong>Nombre de Categoría</strong></label>
                            <InputText class="form-control"
                                       @bind-Value="categoria.Name" />
                            <ValidationMessage For="() => categoria.Name" />
                        </div>

                        <!-- SECCIÓN DETALLE -->
                        <h5 class="section-title mt-4">
                            <i class="bi bi-diagram-3"></i> Subcategorías
                        </h5>

                        <!-- INPUT NUEVO -->
                        <div class="row g-2 mb-3 align-items-end">
                            <div class="col-md-10">
                                <label class="form-label"><strong>Nueva Subcategoría</strong></label>
                                <InputText class="form-control"
                                           @bind-Value="NuevaSubcategoriaNombre"
                                           placeholder="Nueva subcategoría..." />
                            </div>

                            <div class="col-md-2">
                                <button type="button"
                                        class="btn btn-primary w-100 bi bi-plus"
                                        @onclick="AgregarDetalle">
                                    Agregar
                                </button>
                            </div>
                        </div>

                        <!-- TABLA -->
                        <div class="category-detail-table">

                            <QuickGrid Items="categoria.ProductSubcategories.AsQueryable()"
                                       Class="table table-hover">

                                <PropertyColumn Property="@(d => d.Name)"
                                                Title="Subcategoría" />

                                <PropertyColumn Property="@(d => d.ModifiedDate.ToString("dd/MM/yyyy HH:mm"))"
                                                Title="Fecha Modificación" />

                                <TemplateColumn Title="Acción" Class="text-center" Context="category">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger bi bi-trash"
                                            @onclick="(() => RemoverDetalle(category))">
                                        Eliminar
                                    </button>
                                </TemplateColumn>

                            </QuickGrid>

                        </div>

                        <!-- TOTAL -->
                        <div class="mt-3 fw-bold category-total">
                            Total Subcategorías: @categoria.ProductSubcategories.Count
                        </div>

                        <!-- ERROR -->
                        @if (!string.IsNullOrWhiteSpace(mensaje))
                        {
                            <div class="alert alert-danger mt-3">
                                @mensaje
                            </div>
                        }

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer text-center">

                        <a class="btn btn-secondary bi bi-arrow-left"
                               href="/ProductCategory/Index">
                            Volver
                        </a>

                        <button type="submit"
                                class="btn btn-primary bi bi-floppy">
                            Guardar
                        </button>

                        <button type="button"
                                class="btn btn-danger bi bi-trash"
                                @onclick="MostrarModalEliminar">
                            Eliminar
                        </button>

                    </div>
                </div>

            </EditForm>
        </div>

        <!-- MODAL SIMPLE -->
        @if (mostrarModal)
        {
            <div class="category-modal-overlay">
                <div class="category-modal">

                    <p class="fw-bold mb-3">
                        ¿Desea eliminar esta categoría y todas sus subcategorías?
                    </p>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary"
                                @onclick="CerrarModalEliminar">
                            Cancelar
                        </button>

                        <button class="btn btn-danger"
                                @onclick="EliminarConfirmado">
                            Sí, eliminar
                        </button>
                    </div>

                </div>
            </div>
        }

    </div>
}
@code {
    [Parameter] public int Id { get; set; }

    private ProductCategory? categoria;
    private string NuevaSubcategoriaNombre = string.Empty;
    private string mensaje = string.Empty;
    private bool mostrarModal = false;

    protected override async Task OnParametersSetAsync()
    {
        categoria = await categoryService.Buscar(Id);
        if (categoria == null)
        {
            mensaje = "Categoría no encontrada";
        }
    }

    private void AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(NuevaSubcategoriaNombre))
        {
            mensaje = "Debe escribir un nombre para la subcategoría";
            return;
        }

        categoria!.ProductSubcategories.Add(new ProductSubcategory
        {
            Name = NuevaSubcategoriaNombre,
            ProductCategoryId = categoria.ProductCategoryId
        });

        toastService.ShowSuccess("Detalle agregado correctamente.");
        NuevaSubcategoriaNombre = string.Empty;
        mensaje = string.Empty;
    }

    private void RemoverDetalle(ProductSubcategory det)
    {
        categoria!.ProductSubcategories.Remove(det);
        toastService.ShowWarning("Detalle agregado a borradores.");
    }

    private async Task Guardar()
    {
        if (categoria == null) return;

        if (!categoria.ProductSubcategories.Any())
        {
            mensaje = "Debe agregar al menos un detalle";
            return;
        }

        try
        {
            if (await categoryService.Guardar(categoria))
            {
                toastService.ShowSuccess("Categoría actualizada");
                navigationManager.NavigateTo("/ProductCategory/Index");
            }
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
        }
    }

    private void MostrarModalEliminar() => mostrarModal = true;
    private void CerrarModalEliminar() => mostrarModal = false;

    private async Task EliminarConfirmado()
    {
        if (categoria == null) return;

        try
        {
            if (await categoryService.Eliminar(categoria.ProductCategoryId))
            {
                toastService.ShowSuccess("Categoría eliminada");
                navigationManager.NavigateTo("/ProductCategory/Index");
            }
        }
        catch (AdventureWorksDominicana.Services.ProductDependentDataException ex)
        {
            toastService.ShowError(ex.Message);
        }
        catch (Exception)
        {
            toastService.ShowError("Error inesperado al eliminar.");
        }
        mostrarModal = false;
    }
}