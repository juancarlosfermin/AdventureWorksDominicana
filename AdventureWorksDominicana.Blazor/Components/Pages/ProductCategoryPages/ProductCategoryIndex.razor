@page "/ProductCategory/Index"
@attribute [Authorize(Roles = "Admin, ProductionManager")]


@inject NavigationManager navigationManager
@inject ProductCategoryService productCategoryService
@rendermode InteractiveServer


<PageTitle>Product Category</PageTitle>

<div class="category-container">

    <!-- HEADER -->
    <div class="category-header">
        <div>
            <h3>Product Category</h3>
            <span>Gestión de categorías de productos</span>
        </div>

        <a class="btn btn-primary" href="/ProductCategory/Create">
            <i class="bi bi-plus-square"></i> Crear
        </a>
    </div>

    <!-- FILTROS -->
    <div class="category-filters">

        <div class="row g-3">

            <div class="col-md-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="date" @bind="Desde" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="date" @bind="Hasta" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Filtrar por</label>
                <select class="form-select" @bind="Filtros">
                    <option value="">Seleccione una opción</option>
                    <option value="Id">Id</option>
                    <option value="Nombre">Nombre</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control"
                           type="text"
                           placeholder="Buscar..."
                           @bind="ValorFiltro" />

                    <button class="btn btn-primary" @onclick="Buscar">
                        <i class="bi bi-search"></i>
                    </button>

                    <button class="btn btn-outline-primary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

        </div>

    </div>

    <!-- TABLA -->
    <div class="category-table">

        <QuickGrid Items="ListaCategoriasProducto"
                   Class="table table-hover">

            <PropertyColumn Property="@(e => e.ProductCategoryId)"
                            Sortable="true"
                            Title="ID" />

            <PropertyColumn Property="@(e => e.Name)"
                            Sortable="true"
                            Title="Nombre" />

            <PropertyColumn Property="@(e => e.ModifiedDate)"
                            Format="dd/MM/yyyy"
                            Title="Fecha de modificación"
                            Sortable="true" />

            <TemplateColumn Title="Acciones" Class="text-center">
                <a class="btn btn-sm btn-outline-primary"
                       href="/ProductCategory/Edit/@context.ProductCategoryId">
                    <i class="bi bi-pencil"></i> Modificar
                </a>
            </TemplateColumn>

        </QuickGrid>

    </div>

    <!-- FOOTER -->
    <div class="category-footer">
        <strong>Conteo Registros: @ListaCategoriasProducto.Count()</strong>
    </div>

</div>

@code {
    public IQueryable<ProductCategory> ListaCategoriasProducto { get; set; } = Enumerable.Empty<ProductCategory>().AsQueryable();
    public string Filtros { get; set; } = string.Empty;
    public string ValorFiltro { get; set; } = string.Empty;
    public DateTime? Desde { get; set; }
    public DateTime? Hasta { get; set; }


    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    public async Task Buscar()
    {
        List<ProductCategory> resultado;

        if (!string.IsNullOrWhiteSpace(ValorFiltro))
        {
            if (Filtros == "Id" && int.TryParse(ValorFiltro, out int id))
            {
                resultado = await productCategoryService.GetList(x => x.ProductCategoryId == id);
            }
            else if (Filtros == "Nombre")
            {
                resultado = await productCategoryService.GetList(
                    x => x.Name.ToLower().Contains(ValorFiltro.ToLower()));
            }
            else
            {
                resultado = await productCategoryService.GetList(x => true);
            }
        }
        else
        {
            resultado = await productCategoryService.GetList(x => true);
        }

        if (Desde.HasValue)
            resultado = resultado.Where(x => x.ModifiedDate >= Desde.Value).ToList();

        if (Hasta.HasValue)
            resultado = resultado.Where(x => x.ModifiedDate <= Hasta.Value).ToList();

        ListaCategoriasProducto = resultado.AsQueryable();
    }

    private async Task Restablecer()
    {
        Desde = null;
        Hasta = null;
        ValorFiltro = string.Empty;
        Filtros = string.Empty;
        await Buscar();
    }
}