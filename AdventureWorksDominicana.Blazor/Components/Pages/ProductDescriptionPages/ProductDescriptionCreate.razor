@page "/ProductDescription/Create"
@attribute [Authorize(Roles = "Admin, ProductionManager")]


@inject ProductDescriptionService productDescriptionService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<div class="product-description-create-container">

    <!-- HEADER -->
    <div class="product-description-create-header">
        <div>
            <h3>Nueva Descripción</h3>
            <span>Registro de contenido comercial para productos</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="product-description-create-form">
        <EditForm Model="ProductDesc" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-file-text"></i> Contenido Comercial
                    </h5>

                    <!-- DESCRIPCIÓN -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Párrafo de Descripción</strong>
                        </label>

                        <textarea class="form-control"
                                  rows="5"
                                  maxlength="400"
                                  @bind="ProductDesc.Description"
                                      placeholder="Ej: Bicicleta de alto rendimiento diseñada para recorridos de montaña extremo...">
                        </textarea>

                            <ValidationMessage For="(() => ProductDesc.Description)" />

                            <small class="text-muted">
                                Evita mencionar colores o tamaños específicos, redacta pensando en la línea general del modelo.
                            </small>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer text-center">
                        <a class="btn btn-secondary bi bi-arrow-left" href="/ProductDescription/Index">
                            Volver
                        </a>

                        <button class="btn btn-primary bi bi-floppy" type="submit">
                            Guardar
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

    </div>

@code {
    public ProductDescription ProductDesc { get; set; } = new ProductDescription();

    public async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(ProductDesc.Description))
        {
            toastService.ShowWarning("La descripción no puede estar vacía.");
            return;
        }

        var existeDuplicado = await productDescriptionService.GetList(d => d.Description.ToLower().Trim() == ProductDesc.Description.ToLower().Trim());
        if (existeDuplicado.Any())
        {
            toastService.ShowWarning("Esta descripción exacta ya existe en el sistema.");
            return;
        }

        bool guardado = await productDescriptionService.Guardar(ProductDesc);
        if (guardado)
        {
            toastService.ShowSuccess("Descripción registrada correctamente en el banco de textos.");
            navigationManager.NavigateTo("/ProductDescription/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar.");
        }
    }
}
