@page "/ProductDescription/Edit/{DescriptionId:int}"
@attribute [Authorize(Roles = "Admin, ProductionManager")]


@inject ProductDescriptionService productDescriptionService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<div class="product-description-edit-container">

    <!-- HEADER -->
    <div class="product-description-edit-header">
        <div>
            <h3>Modificar Descripción</h3>
            <span>Edición de contenido comercial existente</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="product-description-edit-form">
        <EditForm Model="ProductDesc" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-file-text"></i> Contenido Comercial
                    </h5>

                    <!-- ID -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>ID Descripción</strong>
                        </label>

                        <input class="form-control"
                               value="@ProductDesc.ProductDescriptionId"
                               disabled />
                    </div>

                    <!-- DESCRIPCIÓN -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Párrafo de Descripción</strong>
                        </label>

                        <textarea class="form-control"
                                  rows="5"
                                  maxlength="400"
                                      @bind="ProductDesc.Description">
                        </textarea>

                            <ValidationMessage For="(() => ProductDesc.Description)" />

                            <small class="text-danger">
                                ¡Atención! Cualquier cambio aquí se reflejará automáticamente en todos los modelos vinculados.
                            </small>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer text-center">

                        <a class="btn btn-secondary bi bi-arrow-left" href="/ProductDescription/Index">
                            Volver
                        </a>

                        <button class="btn btn-primary bi bi-floppy" type="submit">
                            Modificar
                        </button>

                        <button class="btn btn-danger bi bi-trash" type="button" @onclick="Eliminar">
                            Eliminar
                        </button>

                    </div>
                </div>
            </EditForm>
        </div>

    </div>

@code {
    [Parameter]
    public int DescriptionId { get; set; }

    public ProductDescription ProductDesc { get; set; } = new ProductDescription();

    protected override async Task OnInitializedAsync()
    {
        var descEncontrado = await productDescriptionService.Buscar(DescriptionId);
        if (descEncontrado == null)
        {
            toastService.ShowError("No se pudo encontrar la descripción en el sistema.");
            navigationManager.NavigateTo("/ProductDescription/Index");
            return;
        }
        ProductDesc = descEncontrado;
    }

    public async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(ProductDesc.Description))
        {
            toastService.ShowWarning("La descripción no puede estar vacía.");
            return;
        }

        bool guardado = await productDescriptionService.Guardar(ProductDesc);
        if (guardado)
        {
            toastService.ShowSuccess("La descripción se ha actualizado correctamente.");
            navigationManager.NavigateTo("/ProductDescription/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar.");
        }
    }

    public async Task Eliminar()
    {
        try
        {
            bool eliminado = await productDescriptionService.Eliminar(ProductDesc.ProductDescriptionId);
            if (eliminado)
            {
                toastService.ShowSuccess("La descripción se eliminó del banco de textos.");
                navigationManager.NavigateTo("/ProductDescription/Index");
            }
            else
            {
                toastService.ShowError("No se pudo eliminar de la base de datos.");
            }
        }
        catch (Exception)
        {
            toastService.ShowError("No es posible eliminarla. Es probable que esté vinculada a algún Modelo.");
        }
    }
}
