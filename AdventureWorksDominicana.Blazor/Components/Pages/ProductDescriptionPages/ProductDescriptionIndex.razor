@page "/ProductDescription/Index"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@rendermode InteractiveServer
@inject ProductDescriptionService productDescriptionService

<PageTitle>Banco de Descripciones de Producto</PageTitle>

<div class="product-description-container">

    <!-- HEADER -->
    <div class="product-description-header">
        <div>
            <h3>Banco de Descripciones</h3>
            <span>Gestión de descripciones de productos</span>
        </div>

        <a href="/ProductDescription/Create" class="btn btn-primary">
            <i class="bi bi-plus-square"></i> Crear
        </a>
    </div>

    <!-- FILTROS -->
    <div class="product-description-filters">
        <div class="row g-3">

            <div class="col-md-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="date" @bind="StartDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="date" @bind="EndDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Filtro</label>
                <select class="form-select" @bind="Filtro">
                    <option value="">Seleccione...</option>
                    <option value="Id">ID</option>
                    <option value="Descripcion">Descripción</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control" placeholder="Buscar..." @bind="ValorFiltro" />

                    <button class="btn btn-primary" @onclick="Buscar">
                        <i class="bi bi-search"></i>
                    </button>

                    <button class="btn btn-outline-primary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- TABLA -->
    <div class="product-description-table">

        <QuickGrid Items="DescriptionsList.AsQueryable()"
                   Pagination="@pages"
                   Class="table table-hover">

            <PropertyColumn Property="@(d => d.ProductDescriptionId)"
                            Title="ID" Sortable="true" />

            <PropertyColumn Property="@(d => d.Description)"
                            Title="Descripción" Sortable="true" />

            <PropertyColumn Property="@(d => d.ModifiedDate)"
                            Title="Fecha" Format="dd/MM/yyyy" Sortable="true" />

            <TemplateColumn Title="Acciones" Class="text-center">
                <a href="/ProductDescription/Edit/@context.ProductDescriptionId"
                       class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Modificar
                </a>
            </TemplateColumn>

        </QuickGrid>

        <Paginator State="@pages" />

    </div>

</div>

@code {
    private List<ProductDescription> DescriptionsList = new List<ProductDescription>();
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };
    private string Filtro = string.Empty;
    private string ValorFiltro = string.Empty;
    private DateTime? StartDate = null;
    private DateTime? EndDate = null;

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    private async Task Buscar()
    {
        int.TryParse(ValorFiltro, out int idBuscado);

        DescriptionsList = await productDescriptionService.GetList(d =>
            (!(StartDate.HasValue && EndDate.HasValue) ||
            (d.ModifiedDate >= StartDate.Value.Date && d.ModifiedDate <= EndDate.Value.Date.AddDays(1).AddTicks(-1)))
            &&
            (string.IsNullOrWhiteSpace(ValorFiltro) || string.IsNullOrWhiteSpace(Filtro) ||
                (Filtro == "Id" && d.ProductDescriptionId == idBuscado) ||
                (Filtro == "Descripcion" && d.Description.Contains(ValorFiltro))
            )
        );

        DescriptionsList = DescriptionsList.OrderByDescending(d => d.ModifiedDate).ToList();
    }

    private async Task Restablecer()
    {
        StartDate = null;
        EndDate = null;
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
        await Buscar();
    }
}