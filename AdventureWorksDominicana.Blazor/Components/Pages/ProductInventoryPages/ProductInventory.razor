@page "/Product/Inventory"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@rendermode InteractiveServer
@using AdventureWorksDominicana.Services
@using AdventureWorksDominicana.Data.Models
@using InventoryModel = AdventureWorksDominicana.Data.Models.ProductInventory

@inject ProductInventoryService InventoryService

<PageTitle>Inventario de Bodegas</PageTitle>

<div class="container-fluid mt-4">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h3 class="mb-0 text-dark fw-bold">Control de Almacén</h3>
                <p class="text-muted small mb-0">Existencias físicas por ubicación</p>
            </div>
            <a href="/Product/InventoryEntry" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-box-arrow-in-right me-1"></i> Dar Entrada a Productos
            </a>
        </div>

        <div class="card-body px-4">
            <div class="mb-4 w-50">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="search" class="form-control bg-light border-0 shadow-none" 
                           placeholder="Buscar producto por nombre..."
                           @bind="Filtro" @bind:event="oninput" />
                </div>
            </div>

            <div class="table-responsive">
                <QuickGrid Items="@FilteredInventory" Pagination="@pagination" Class="table table-hover align-middle border-top">
                    
                    <TemplateColumn Title="Producto" Sortable="true" SortBy="@(GridSort<InventoryModel>.ByAscending(x => x.Product != null ? x.Product.Name : string.Empty))">
                        <div class="d-flex flex-column">
                            <strong class="text-dark">@(context.Product?.Name ?? "Sin Nombre")</strong>
                            <div class="d-flex gap-1 mt-1">
                                <span class="badge bg-light text-muted border fw-normal">Estante @context.Shelf</span>
                                <span class="badge bg-light text-muted border fw-normal">Bin @context.Bin</span>
                            </div>
                        </div>
                    </TemplateColumn>

                    <TemplateColumn Title="Ubicación" Sortable="true" SortBy="@(GridSort<InventoryModel>.ByAscending(x => x.Location != null ? x.Location.Name : string.Empty))">
                        @context.Location?.Name
                    </TemplateColumn>
                    
                    <PropertyColumn Property="@(p => p.Quantity)" Title="Cantidad" Align="Align.Center" Sortable="true" />

                    <TemplateColumn Title="Estado" Align="Align.Center">
                        @if (context.Quantity <= (context.Product?.SafetyStockLevel ?? 0))
                        {
                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3">STOCK BAJO</span>
                        }
                        else
                        {
                            <span class="badge bg-success-subtle text-success rounded-pill px-3">STOCK ADECUADO</span>
                        }
                    </TemplateColumn>

                    <TemplateColumn Title="Ajuste Rápido" Align="Align.Center">
                        <div class="btn-group shadow-sm rounded-pill bg-light border p-1">
                            <button class="btn btn-sm btn-white border-0 rounded-circle me-1"
                                    @onclick="() => Ajustar(context, -1)"
                                    disabled="@(context.Quantity <= 0)"
                                    title="Restar 1">
                                <i class="bi bi-dash-lg text-danger"></i>
                            </button>
                            <button class="btn btn-sm btn-white border-0 rounded-circle"
                                    @onclick="() => Ajustar(context, 1)"
                                    title="Sumar 1">
                                <i class="bi bi-plus-lg text-success"></i>
                            </button>
                        </div>
                    </TemplateColumn>
                </QuickGrid>
            </div>

            <div class="mt-4 d-flex justify-content-end align-items-center border-top pt-3 pb-2">
                <Paginator State="@pagination" />
            </div>
        </div>
    </div>
</div>

@code {
    private List<InventoryModel>? inventario;
    private string Filtro = string.Empty;
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task CargarDatos() => inventario = await InventoryService.GetList(i => true);

    private IQueryable<InventoryModel> FilteredInventory
    {
        get
        {
            var query = inventario?.AsQueryable() ?? Enumerable.Empty<InventoryModel>().AsQueryable();
            if (!string.IsNullOrWhiteSpace(Filtro))
            {
                query = query.Where(x => x.Product != null && x.Product.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));
            }
            return query;
        }
    }

    private async Task Ajustar(InventoryModel item, short cantidad)
    {
        if (cantidad < 0 && item.Quantity <= 0) return;
        if (await InventoryService.AjustarExistencia(item.ProductId, item.LocationId, cantidad))
        {
            item.Quantity = (short)(item.Quantity + cantidad);
            StateHasChanged(); 
        }
    }
}