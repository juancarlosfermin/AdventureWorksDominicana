@page "/Product/InventoryEntry"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@rendermode InteractiveServer

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using InventoryModel = AdventureWorksDominicana.Data.Models.ProductInventory

@inject ProductInventoryService InventoryService
@inject ProductService productService
@inject LocationService locationService
@inject ToastService toastService
@inject NavigationManager navigationManager

<PageTitle>Entrada de Inventario</PageTitle>

<div class="inventory-entry-container">

    <!-- HEADER -->
    <div class="inventory-entry-header">
        <div>
            <h3>Registrar Entrada</h3>
            <span>Ingreso de productos al inventario</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="inventory-entry-form">
        <EditForm Model="nuevaEntrada" FormName="FormularioEntrada" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-box-arrow-in-down"></i> Información de Entrada
                    </h5>

                    <!-- PRODUCTO -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Producto</strong></label>

                        <InputSelect class="form-select"
                                     @bind-Value="nuevaEntrada.ProductId"
                                     @bind-Value:after="ConsultarStockActual">
                            <option value="0">Seleccionar Producto</option>
                            @foreach (var p in ListaProductos)
                            {
                                <option value="@p.ProductId">[@p.ProductNumber] @p.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <!-- UBICACIÓN -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Almacén de Destino</strong></label>

                        <InputSelect class="form-select"
                                     @bind-Value="nuevaEntrada.LocationId"
                                     @bind-Value:after="ConsultarStockActual">
                            <option value="0">Seleccionar Almacén</option>
                            @foreach (var l in ListaUbicaciones)
                            {
                                <option value="@l.LocationId">@l.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <!-- CANTIDAD -->
                    <div class="mb-3">
                        <div class="label-row">
                            <label class="form-label"><strong>Cantidad Entrante</strong></label>

                            @if (nuevaEntrada.ProductId > 0 && nuevaEntrada.LocationId > 0)
                            {
                                <span class="stock-badge @(stockActual > 0 ? "ok" : "low")">
                                    Stock actual: @stockActual
                                </span>
                            }
                        </div>

                        <InputNumber class="form-control quantity-input"
                                     @bind-Value="nuevaEntrada.Quantity" />
                    </div>

                    <!-- UBICACIÓN INTERNA -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Estante</strong></label>

                            <InputSelect class="form-select"
                                         @bind-Value="nuevaEntrada.Shelf">
                                <option value="A">Estante A</option>
                                <option value="B">Estante B</option>
                                <option value="C">Estante C</option>
                                <option value="N/A">N/A</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Cajón</strong></label>

                            <InputSelect class="form-select"
                                         @bind-Value="nuevaEntrada.Bin">
                                @for (byte i = 1; i <= 20; i++)
                                {
                                    <option value="@i">Cajón @i</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">

                    <a class="btn btn-secondary bi bi-arrow-left"
                           href="/Product/Inventory">
                        Cancelar
                    </a>

                    <button class="btn btn-primary bi bi-floppy"
                            type="submit">
                        Confirmar
                    </button>

                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public InventoryModel nuevaEntrada { get; set; } = new() { Quantity = 1, Shelf = "A", Bin = 1 };
    public List<Product> ListaProductos { get; set; } = new();
    public List<Location> ListaUbicaciones { get; set; } = new();
    private short stockActual = 0;

    protected override async Task OnInitializedAsync()
    {
        ListaProductos = await productService.GetList(p => !p.ProductInventories.Any());
        ListaUbicaciones = await locationService.GetList(x => true);
    }

    private async Task ConsultarStockActual()
    {
        if (nuevaEntrada.ProductId > 0 && nuevaEntrada.LocationId > 0)
        {
            var item = await InventoryService.Buscar(nuevaEntrada.ProductId, (short)nuevaEntrada.LocationId);
            if (item != null)
            {
                stockActual = item.Quantity;
                nuevaEntrada.Shelf = item.Shelf;
                nuevaEntrada.Bin = item.Bin;
            }
            else stockActual = 0;
        }
    }

    public async Task Guardar()
    {
        if (await InventoryService.Guardar(nuevaEntrada))
        {
            toastService.ShowSuccess("Entrada registrada.");
            navigationManager.NavigateTo("/Product/Inventory");
        }
    }
}