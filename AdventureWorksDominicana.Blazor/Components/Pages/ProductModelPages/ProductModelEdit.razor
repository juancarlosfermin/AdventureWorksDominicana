@page "/ProductModel/Edit/{Id:int}"
@using AdventureWorksDominicana.Blazor.Helpers
@using AdventureWorksDominicana.Data.Models.DTOs
@attribute [Authorize(Roles = "Admin, ProductionManager")]
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductModelService modelService
@inject ProductDescriptionService descriptionService
@inject CultureService cultureService
@rendermode InteractiveServer

<PageTitle>Editar Modelo</PageTitle>

@if (model == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />

        <div class="container mt-4">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4 class="mb-0">Editar Modelo de Producto</h4>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">ID Modelo</label>
                        <InputNumber class="form-control" @bind-Value="model.ProductModelId" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Modelo</label>
                        <InputText class="form-control" @bind-Value="model.Name" />
                        <ValidationMessage For="() => model.Name" />
                    </div>

                    <div class="row mb-3">
                        <!-- ✅ AQUÍ ARREGLAMOS EL ERROR DE COMPILACIÓN -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Resumen de Catálogo</label>
                            <InputText class="form-control" @bind-Value="catalogDto.Summary" placeholder="Ej: Bicicleta de montaña premium..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Instrucciones</label>
                            <!-- Apoyándonos en el DTO anidado -->
                            <InputText class="form-control" @bind-Value="instructionsDto.Location.Step" placeholder="Ej: Ajustar tuercas B primero" />
                        </div>
                    </div>

                    <!-- DETALLE: Descripciones (Patrón exacto de ProductCategory) -->
                    <div class="border border-success p-3 mb-3">
                        <h3 class="mb-3">Textos Comerciales</h3>
                        <div class="row mb-3 g-2">
                            <div class="col-md-3">
                                <select class="form-select" @bind="nuevaCulturaId">
                                    <option value="">Cultura...</option>
                                    @foreach (var c in ListaCulturas)
                                    {
                                        <option value="@c.CultureId">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-7">
                                <InputTextArea class="form-control" rows="1" @bind-Value="nuevoTexto" placeholder="Descripción comercial..." />

                            </div>
                            <div class="col-md-2 text-center">
                                <button type="button" class="btn btn-primary bi bi-plus" @onclick="AgregarDetalle"> Agregar</button>
                            </div>
                        </div>

                        <QuickGrid Items="model.ProductModelProductDescriptionCultures.AsQueryable()" Class="table table-striped table-bordered table-hover">
                            <TemplateColumn Title="Idioma" Context="item">
                                <span class="badge bg-secondary">@item.CultureId</span>
                            </TemplateColumn>
                            <TemplateColumn Title="Descripción" Context="item">
                                @item.ProductDescription?.Description
                            </TemplateColumn>
                            <TemplateColumn Class="text-center" Title="Acción" Context="item">
                                <button type="button" class="btn btn-danger btn-sm bi bi-trash" @onclick="(() => RemoverDetalle(item))"> Eliminar</button>
                            </TemplateColumn>
                        </QuickGrid>
                    </div>

                    <div class="mt-3 fw-bold">
                        Total Idiomas: @model.ProductModelProductDescriptionCultures.Count
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensajeError))
                    {
                        <div class="alert alert-danger">
                            @mensajeError
                        </div>
                    }
                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/ProductModel/Index"> Volver</a>
                    <button type="submit" class="btn btn-primary bi bi-file-earmark"> Guardar</button>
                    <button type="button" class="btn btn-danger bi bi-trash" @onclick="MostrarConfirmacion"> Eliminar</button>
                </div>
            </div>

            <!-- CONFIRMACIÓN DE ELIMINACIÓN (Patrón exacto de ProductCategory) -->
            @if (confirmarEliminar)
            {
                <div class="alert alert-danger mt-3">
                    <p>¿Desea eliminar este modelo y todas sus asociaciones?</p>
                    <button type="button" class="btn btn-secondary me-2" @onclick="CerrarConfirmacion"> Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarConfirmado"> Si, eliminar</button>
                </div>
            }
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private ProductModel? model;
    private List<Culture> ListaCulturas = new();
    private string nuevaCulturaId = "", nuevoTexto = "", mensajeError = "";
    private bool confirmarEliminar = false;

    private CatalogDto catalogDto = new();
    private InstructionsDto instructionsDto = new();

    protected override async Task OnInitializedAsync()
    {
        model = await modelService.Buscar(Id);
        ListaCulturas = await cultureService.GetList(c => true);
        if (model != null)
        {
            catalogDto = XmlHelper.DeserializarDesdeXml<CatalogDto>(model.CatalogDescription) ?? new();
            instructionsDto = XmlHelper.DeserializarDesdeXml<InstructionsDto>(model.Instructions) ?? new();
        }
    }

    private async Task AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(nuevaCulturaId) || string.IsNullOrWhiteSpace(nuevoTexto)) return;

        if (model!.ProductModelProductDescriptionCultures.Any(c => c.CultureId == nuevaCulturaId))
        {
            toastService.ShowWarning("Ya existe un texto comercial configurado para este idioma.");
            return;
        }

        var pDesc = new ProductDescription { Description = nuevoTexto };
        if (await descriptionService.Guardar(pDesc))
        {
            model!.ProductModelProductDescriptionCultures.Add(new ProductModelProductDescriptionCulture
            {
                CultureId = nuevaCulturaId,
                ProductDescriptionId = pDesc.ProductDescriptionId,
                ProductDescription = pDesc
            });
            nuevoTexto = "";
            toastService.ShowSuccess("Texto agregado correctamente.");
            
            model.ProductModelProductDescriptionCultures = model.ProductModelProductDescriptionCultures.ToList();
            StateHasChanged();
        }
    }

    private void RemoverDetalle(ProductModelProductDescriptionCulture item)
    {
        model!.ProductModelProductDescriptionCultures.Remove(item);
        toastService.ShowWarning("Eliminado de la lista.");
    }

    private async Task Guardar()
    {
        try
        {
            // ✅ AQUÍ INTEGRAMOS LA LÓGICA DE DTOs PARA PODER GUARDAR LA EDICIÓN
            model!.CatalogDescription = !string.IsNullOrWhiteSpace(catalogDto.Summary)
                                        ? XmlHelper.SerializarAXml(catalogDto)
                                        : null;
                                        
            model.Instructions = !string.IsNullOrWhiteSpace(instructionsDto.Location.Step)
                                       ? XmlHelper.SerializarAXml(instructionsDto)
                                       : null;


            if (await modelService.Guardar(model!))
            {
                toastService.ShowSuccess("Modelo guardado exitosamente.");
                navigationManager.NavigateTo("/ProductModel/Index");
            }
            else
            {
                toastService.ShowError("No se pudo guardar el modelo.");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al guardar: {ex.Message}");
            if (ex.InnerException != null)
            {
                toastService.ShowError($"Detalle técnico: {ex.InnerException.Message}");
                Console.WriteLine(ex.InnerException.Message);
            }
        }
    }

    private void MostrarConfirmacion() => confirmarEliminar = true;
    private void CerrarConfirmacion() => confirmarEliminar = false;

    private async Task EliminarConfirmado()
    {
        try
        {
            if (await modelService.Eliminar(Id))
            {
                toastService.ShowSuccess("Modelo eliminado.");
                navigationManager.NavigateTo("/ProductModel/Index");
            }
        }
        catch (Exception ex) { toastService.ShowError(ex.Message); confirmarEliminar = false; }
    }
}