@page "/Product/Create"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@inject ProductService productService;
@inject ProductSubcategoryService subcategoryService;
@inject ProductModelService modelService;
@inject UnitMeasureService unitMeasureService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

@inject ProductService productService
@inject ProductSubcategoryService productSubcategoryService
@inject ProductModelService productModelService
@inject UnitMeasureService unitMeasureService
@inject ToastService toastService
@inject NavigationManager navigationManager

<PageTitle>Crear Producto</PageTitle>

<div class="product-container">
    
    <!-- HEADER -->
    <div class="product-header">
        <div>
            <h3>Crear Producto</h3>
            <span>Registro de nuevos productos en el catálogo</span>
        </div>
    </div>

    <!-- FORMULARIO -->
    <div class="product-form">
        <EditForm Model="Product" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN: INFORMACIÓN BÁSICA -->
                    <h5 class="section-title">
                        <i class="bi bi-info-circle"></i> Información General
                    </h5>
                    
                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <input class="form-control" type="text" @bind="Product.Name" placeholder="Ej: Mountain Bike 1000" />
                        <ValidationMessage For="(() => Product.Name)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Número de producto</strong></label>
                        <input class="form-control" type="text" @bind="Product.ProductNumber" placeholder="Ej: MT-1000" />
                        <ValidationMessage For="(() => Product.ProductNumber)" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" @bind="Product.MakeFlag" id="MakeFlag" />
                                <label class="form-check-label" for="MakeFlag">Fabricación propia</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" @bind="Product.FinishedGoodsFlag" id="FinishedGoodsFlag" />
                                <label class="form-check-label" for="FinishedGoodsFlag">Producto terminado</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Color</strong></label>
                        <input class="form-control" type="text" @bind="Product.Color" placeholder="Ej: Rojo, Negro" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Tamaño</strong></label>
                        <input class="form-control" type="text" @bind="Product.Size" placeholder="Ej: M, L, XL" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Peso</strong></label>
                        <div class="input-group">
                            <input class="form-control" type="number" step="0.01" @bind="Product.Weight" placeholder="0.00" />
                            <select class="form-select" style="max-width: 100px;" @bind="Product.WeightUnitMeasureCode">
                                <option value="">Unidad</option>
                                @foreach (var u in ListaUnidades)
                                {
                                    <option value="@u.UnitMeasureCode">@u.UnitMeasureCode</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- SECCIÓN: COSTOS Y PRECIOS -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-currency-dollar"></i> Costos y Precios
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Costo estándar</strong></label>
                        <div class="input-group">
                            <span class="input-group-text">RD$</span>
                            <input class="form-control" type="number" step="0.01" min="0" @bind="Product.StandardCost" />
                        </div>
                        <ValidationMessage For="(() => Product.StandardCost)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Precio de lista</strong></label>
                        <div class="input-group">
                            <span class="input-group-text">RD$</span>
                            <input class="form-control" type="number" step="0.01" min="0" @bind="Product.ListPrice" />
                        </div>
                        <ValidationMessage For="(() => Product.ListPrice)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Días de fabricación</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.DaysToManufacture" />
                        <ValidationMessage For="(() => Product.DaysToManufacture)" />
                    </div>

                    <!-- SECCIÓN: INVENTARIO -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-box-seam"></i> Inventario
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Stock de seguridad</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.SafetyStockLevel" />
                        <ValidationMessage For="(() => Product.SafetyStockLevel)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Punto de reorden</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.ReorderPoint" />
                        <ValidationMessage For="(() => Product.ReorderPoint)" />
                    </div>

                    <!-- SECCIÓN: CLASIFICACIÓN -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-tags"></i> Clasificación
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Línea de producto</strong></label>
                        <select class="form-select" @bind="Product.ProductLine">
                            <option value="">— Seleccione —</option>
                            <option value="R">Road (R)</option>
                            <option value="M">Mountain (M)</option>
                            <option value="T">Touring (T)</option>
                            <option value="S">Standard (S)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Clase</strong></label>
                        <select class="form-select" @bind="Product.Class">
                            <option value="">— Seleccione —</option>
                            <option value="H">High (H)</option>
                            <option value="M">Medium (M)</option>
                            <option value="L">Low (L)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Estilo</strong></label>
                        <select class="form-select" @bind="Product.Style">
                            <option value="">— Seleccione —</option>
                            <option value="W">Women's (W)</option>
                            <option value="M">Men's (M)</option>
                            <option value="U">Universal (U)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Subcategoría</strong></label>
                        <select class="form-select" @bind="Product.ProductSubcategoryId">
                            <option value="">— Ninguna —</option>
                            @foreach (var s in ListaSubcategorias)
                            {
                                <option value="@s.ProductSubcategoryId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Modelo de producto</strong></label>
                        <select class="form-select" @bind="Product.ProductModelId">
                            <option value="">— Ninguno —</option>
                            @foreach (var m in ListaModelos)
                            {
                                <option value="@m.ProductModelId">@m.Name</option>
                            }
                        </select>
                    </div>

                    <!-- SECCIÓN: FECHAS -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-calendar3"></i> Fechas
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Inicio de ventas</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.SellStartDate" />
                        <ValidationMessage For="(() => Product.SellStartDate)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Fin de ventas</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.SellEndDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Fecha discontinuación</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.DiscontinuedDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Fecha de modificación</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.ModifiedDate" disabled />
                    </div>

                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/Product/Index"> Volver</a>
                    <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public Product Product { get; set; } = new();
    public List<ProductSubcategory> ListaSubcategorias { get; set; } = new();
    public List<ProductModel> ListaModelos { get; set; } = new();
    public List<UnitMeasure> ListaUnidades { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Product.MakeFlag = true;
        Product.FinishedGoodsFlag = true;
        Product.SafetyStockLevel = 1000;
        Product.ReorderPoint = 750;
        Product.DaysToManufacture = 0;
        Product.StandardCost = 0;
        Product.ListPrice = 0;
        Product.SellStartDate = DateTime.Now;

        ListaSubcategorias = await subcategoryService.GetList(s => s.ProductSubcategoryId > 0);
        ListaModelos = await modelService.GetList(m => m.ProductModelId > 0);
        ListaUnidades = await unitMeasureService.GetList(u => true);
    }

    public async Task Guardar()
    {
        // Limpiar valores vacíos
        Product.WeightUnitMeasureCode = string.IsNullOrWhiteSpace(Product.WeightUnitMeasureCode) ? null : Product.WeightUnitMeasureCode;
        Product.ProductLine = string.IsNullOrWhiteSpace(Product.ProductLine) ? null : Product.ProductLine;
        Product.Class = string.IsNullOrWhiteSpace(Product.Class) ? null : Product.Class;
        Product.Style = string.IsNullOrWhiteSpace(Product.Style) ? null : Product.Style;

        // Validar duplicados
        var duplicado = await productService.GetList(p =>
            (p.Name.ToLower().Trim() == Product.Name.ToLower().Trim()
             || p.ProductNumber.ToLower().Trim() == Product.ProductNumber.ToLower().Trim())
            && p.ProductId != Product.ProductId);

        if (duplicado.Any())
        {
            toastService.ShowWarning("Ya existe otro producto con el mismo nombre o número de producto.");
            return;
        }

        bool guardado = await productService.Guardar(Product);
        if (guardado)
        {
            toastService.ShowSuccess("Producto creado exitosamente.");
            navigationManager.NavigateTo("/Product/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar el producto.");
        }
    }
}
