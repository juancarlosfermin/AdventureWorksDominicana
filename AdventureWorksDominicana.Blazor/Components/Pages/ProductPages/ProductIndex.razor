@page "/Product/Index"
@attribute [Authorize(Roles = "Admin, ProductionManager, SalesManager")]

@inject ProductService productService;
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<div class="product-container">

    <!-- HEADER -->
    <div class="product-header">
        <div>
            <h3>Productos</h3>
            <span>Gestión y consulta de catálogo</span>
        </div>

        <AuthorizeView Roles="Admin, ProductionManager">
            <Authorized>
                <a class="btn btn-primary" href="/Product/Create">
                    <i class="bi bi-plus-square"></i> Crear
                </a>
            </Authorized>
        </AuthorizeView>
    </div>

    <!-- FILTROS -->
    <div class="product-filters">
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="datetime-local" @bind="FechaDesde" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="datetime-local" @bind="FechaHasta" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Filtro</label>
                <select class="form-select" @bind="Filtro">
                    <option value="">Seleccione...</option>
                    <option value="Nombre">Nombre</option>
                    <option value="Numero">SKU</option>
                    <option value="Subcategoria">Subcategoría</option>
                </select>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
                    <button class="btn btn-primary" @onclick="Filtrar">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-outline-primary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLA -->
    <div class="table-responsive product-table">

        <QuickGrid Class="table table-hover" Items="ListaProducts.AsQueryable()" Pagination="@pages" ItemKey="@(p => p.ProductId)">

            <PropertyColumn Property="@(p => p.ProductId)" Title="ID" />
            <PropertyColumn Property="@(p => p.ProductNumber)" Title="SKU" />
            <PropertyColumn Property="@(p => p.Name)" Title="Nombre" />

            <TemplateColumn Context="p" Title="Subcategoría">
                @(p.ProductSubcategory?.Name ?? "N/A")
            </TemplateColumn>

            <PropertyColumn Property="@(p => p.StandardCost)" Format="C2" Title="Costo" />
            <PropertyColumn Property="@(p => p.ListPrice)" Format="C2" Title="Precio" />

            <TemplateColumn Context="p" Title="Estado">
                @if (p.SellEndDate == null)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactivo</span>
                }
            </TemplateColumn>

            @if (canEdit)
            {
                <TemplateColumn Class="text-center" Context="p" Title="Acciones">
                    <a href="/Product/Edit/@p.ProductId" class="btn btn-sm btn-outline-primary">
                        <span class="bi bi-pencil"></span> Modificar
                    </a>
                </TemplateColumn>
            }

        </QuickGrid>

        <Paginator State="@pages" />

    </div>
</div>

@code {
    public List<Product> ListaProducts { get; set; } = new List<Product>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 10 };
    private bool canEdit = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        canEdit = user.IsInRole("Admin") || user.IsInRole("ProductionManager");

        ListaProducts = await productService.GetListIndex(p => p.ProductId > 0);
        ListaProducts = ListaProducts.OrderByDescending(p => p.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<Product, bool>> criterio = p => p.ProductId > 0;

        // FILTROS DE FECHA (Usando ModifiedDate, vital para auditoría de productos)
        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHastaStr = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(p => p.ModifiedDate >= FechaDesde.Value && p.ModifiedDate <= fechaHastaStr);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(p => p.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHastaStr = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(p => p.ModifiedDate <= fechaHastaStr);
        }

        // FILTROS DE TEXTO
        if (!string.IsNullOrEmpty(Filtro) && !string.IsNullOrEmpty(ValorFiltro))
        {
            if (Filtro == "Nombre")
            {
                criterio = criterio.And(p => p.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            else if (Filtro == "Numero")
            {
                criterio = criterio.And(p => p.ProductNumber.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            else if (Filtro == "Subcategoria")
            {
                // Validación de null conditional en expresiones requiere cuidado, pero como ya incluimos Subcategory en GetList:
                criterio = criterio.And(p => p.ProductSubcategory != null && p.ProductSubcategory.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }

        ListaProducts = await productService.GetListIndex(criterio);
        ListaProducts = ListaProducts.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
