@page "/ProductVendor/Index"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@rendermode InteractiveServer
@inject ProductVendorService productVendorService

<PageTitle>Product Vendor</PageTitle>

<div class="product-vendor-container">

    <!-- HEADER -->
    <div class="product-vendor-header">
        <div>
            <h3>Product Vendor</h3>
            <span>Gestión de productos por proveedor</span>
        </div>

        <a href="/ProductVendor/Create" class="btn btn-primary">
            <i class="bi bi-plus-square"></i> Crear
        </a>
    </div>

    <!-- FILTROS -->
    <div class="product-vendor-filters">
        <div class="row g-3">

            <div class="col-md-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="date" @bind="StartDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="date" @bind="EndDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Filtro</label>
                <select class="form-select" @bind="Filtro">
                    <option value="">Seleccione...</option>
                    <option value="Producto">Producto</option>
                    <option value="Vendedor">Proveedor</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control" placeholder="Buscar..." @bind="ValorFiltro" />

                    <button class="btn btn-primary" @onclick="Buscar">
                        <i class="bi bi-search"></i>
                    </button>

                    <button class="btn btn-outline-primary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- TABLA -->
    <div class="product-vendor-table">

        <QuickGrid Items="ProductVendorsList.AsQueryable()"
                   Pagination="@pages"
                   Class="table table-hover">

            <PropertyColumn Property="@(pv => pv.BusinessEntity.Name)"
                            Title="Proveedor" Sortable="true" />

            <PropertyColumn Property="@(pv => pv.Product.Name)"
                            Title="Producto" Sortable="true" />

            <PropertyColumn Property="@(pv => pv.StandardPrice)"
                            Title="Precio Estándar" Sortable="true" />

            <PropertyColumn Property="@(pv => pv.ModifiedDate)"
                            Title="Fecha" Format="dd/MM/yyyy" Sortable="true" />

            <TemplateColumn Title="Acciones" Class="text-center">
                <a href="/ProductVendor/Edit/@context.ProductId/@context.BusinessEntityId"
                       class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Modificar
                </a>
            </TemplateColumn>

        </QuickGrid>

        <Paginator State="@pages" />

    </div>

</div>

@code {
    private List<ProductVendor> ProductVendorsList = new List<ProductVendor>();
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };
    private string Filtro = string.Empty;
    private string ValorFiltro = string.Empty;
    private DateTime? StartDate = null;
    private DateTime? EndDate = null;

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    private async Task Buscar()
    {
        ProductVendorsList = await productVendorService.GetList(pv =>
            (!(StartDate.HasValue && EndDate.HasValue) ||
            (pv.ModifiedDate >= StartDate.Value.Date && pv.ModifiedDate <= EndDate.Value.Date.AddDays(1).AddTicks(-1)))
            &&
            (string.IsNullOrWhiteSpace(ValorFiltro) || string.IsNullOrWhiteSpace(Filtro) ||
                (Filtro == "Producto" && pv.Product.Name.Contains(ValorFiltro)) ||
                (Filtro == "Vendedor" && pv.BusinessEntity.Name.Contains(ValorFiltro))
            )
        );
    }

    private async Task Restablecer()
    {
        StartDate = null;
        EndDate = null;
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
        await Buscar();
    }
}