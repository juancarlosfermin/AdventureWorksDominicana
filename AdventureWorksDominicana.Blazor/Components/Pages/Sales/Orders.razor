@page "/Orders"
@rendermode InteractiveServer
@inject SalesOrderHeaderService salesOrderHeaderService
@inject NavigationManager navigationManager
@inject AuthenticationStateProvider authenticationStateProvider;
<PageTitle>Orders</PageTitle>
<div class="container">
    @* Boton de volver *@
    <span class="btn btn-outline-primary bi bi-arrow-left mb-2" @onclick="GoToSale"> Volver</span>

    <div class="card shadow-lg">
        @*Header*@
        <div class="card-header">
            <h3 class="card-title">Orders</h3>
        </div>
        <div class="card-body">
            @foreach (var s in SalesOrderHeadersList)
            {
                <div class="card order-card shadow border-1 mb-3 bg-light-subtle border-secondary-subtle">

                    <div class="card-body">

                        <!-- Top -->
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="text-muted">
                                @(s.ShipDate?.ToString("dd MMM yyyy") ?? "Sin fecha")
                            </small>

                            <span class="badge @(s.Status == 1 ? "bg-warning text-dark" : "bg-danger")">
                                @(s.Status == 1 ? "En proceso" : "Cancelado")
                            </span>
                        </div>

                        <!-- Info -->
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">Orden #@s.SalesOrderId</div>
                                <small class="text-muted">Total</small>
                            </div>

                            <div class="fw-bold fs-5">
                                RD$ @s.TotalDue
                            </div>
                        </div>

                        <!-- Action -->
                        <div class="mt-3 text-end">
                            <button class="btn btn-sm btn-outline-primary bi bi-file-text" @onclick="() => GoToOrderReview(s.SalesOrderId)">
                                Ver detalles
                            </button>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</div>
@code {
    private List<SalesOrderHeader> SalesOrderHeadersList = new List<SalesOrderHeader>();
    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }
    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;
        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        }
        SalesOrderHeadersList = await salesOrderHeaderService.GetList(s => s.Customer.Person.EmailAddresses.Any(e => e.EmailAddress1.Trim().ToLower().Equals(UserEmail)));
    }

    private void GoToSale() => navigationManager.NavigateTo("/Sales");

    private void GoToOrderReview(int saleId) => navigationManager.NavigateTo($"Order/Review/{saleId}");

}