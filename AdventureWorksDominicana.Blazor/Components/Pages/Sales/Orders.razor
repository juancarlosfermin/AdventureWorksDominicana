@page "/Orders"
@rendermode InteractiveServer
@inject SalesOrderHeaderService salesOrderHeaderService
@inject NavigationManager navigationManager
@inject AuthenticationStateProvider authenticationStateProvider;

<PageTitle>Orders</PageTitle>

<div class="orders-container">

    <!-- HEADER -->
    <div class="orders-header">
        <div>
            <h3>Mis &oacute;rdenes</h3>
            <span>Historial de compras realizadas</span>
        </div>

        <button class="btn btn-outline-primary bi bi-arrow-left" @onclick="GoToSale"> Seguir comprando</button>
    </div>

    <!-- RESUMEN -->
    <div class="orders-summary">

        <div class="summary-card">
            <span>Total órdenes</span>
            <h4>@SalesOrderHeadersList.Count</h4>
        </div>

        <div class="summary-card">
            <span>En proceso</span>
            <h4>@SalesOrderHeadersList.Count(o => o.Status == 1)</h4>
        </div>

        <div class="summary-card">
            <span>Total gastado</span>
            <h4>RD$ @SalesOrderHeadersList.Sum(o => o.TotalDue)</h4>
        </div>

    </div>

    <!-- LISTA -->
    <div class="orders-list">
        @foreach (var s in SalesOrderHeadersList)
        {
            <div class="order-card" @onclick="() => GoToOrderReview(s.SalesOrderId)">

                <div class="order-card-body">

                    <div class="order-top">
                        <div>
                            <span class="order-id">Orden #@s.SalesOrderId</span>
                            <div class="order-date">
                                @(s.ShipDate?.ToString("dd MMM yyyy") ?? "Sin fecha")
                            </div>
                        </div>

                        <span class="order-status @(s.Status == 1 ? "status-processing" : "status-cancelled")">
                            @(s.Status == 1 ? "En proceso" : "Cancelado")
                        </span>
                    </div>

                    <div class="order-total">
                        RD$ @s.TotalDue
                    </div>

                    <div class="order-actions">
                        <button class="btn btn-sm btn-outline-primary">
                            Ver detalles
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>

</div>

@code {
    private List<SalesOrderHeader> SalesOrderHeadersList = new List<SalesOrderHeader>();
    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }
    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;
        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        }
        SalesOrderHeadersList = await salesOrderHeaderService.GetList(s => s.Customer.Person.EmailAddresses.Any(e => e.EmailAddress1.Trim().ToLower().Equals(UserEmail)));
    }

    private void GoToSale() => navigationManager.NavigateTo("/Sales");

    private void GoToOrderReview(int saleId) => navigationManager.NavigateTo($"Order/Review/{saleId}");

}