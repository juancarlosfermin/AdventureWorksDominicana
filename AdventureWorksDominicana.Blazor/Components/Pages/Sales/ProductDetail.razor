@page "/Product/Detail/{ProductId:int}"
@attribute [Authorize(Roles = "Admin, Customer, SalesManager")]

@rendermode InteractiveServer

@inject ProductService productService
@inject ShoppingCartItemService shoppingCartItemService
@inject ToastService toastService
@inject NavigationManager navigationManager
@inject AuthenticationStateProvider authenticationStateProvider

<PageTitle>Producto</PageTitle>

<div class="product-container">

    <div class="product-header">
        <div>
            <h3>Detalle del producto</h3>
            <span>Información completa del producto</span>
        </div>

        <button class="btn-back" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Volver
        </button>
    </div>

    @if (Product != null)
    {
        <div class="product-content">

            <div class="product-image" style="background: white; border-radius: 12px; padding: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); text-align: center;">
                @{
                    var nexoFoto = Product.ProductProductPhotos?.FirstOrDefault(f => f.Primary == true) ?? Product.ProductProductPhotos?.FirstOrDefault();
                    string imgUrl = "https://www.svgrepo.com/show/486796/product-management.svg";

                    if (nexoFoto?.ProductPhoto != null)
                    {
                        if (nexoFoto.ProductPhoto.ThumbNailPhoto != null && nexoFoto.ProductPhoto.ThumbNailPhoto.Length > 0)
                        {
                            var base64 = Convert.ToBase64String(nexoFoto.ProductPhoto.ThumbNailPhoto);
                            imgUrl = $"data:image/jpeg;base64,{base64}";
                        }
                        else if (!string.IsNullOrWhiteSpace(nexoFoto.ProductPhoto.LargePhotoFileName))
                        {
                            imgUrl = ResolverRutaImagen(nexoFoto.ProductPhoto.LargePhotoFileName);
                        }
                    }
                }
                
                <img src="@imgUrl" alt="@Product.Name" style="object-fit: contain; width: 100%; max-height: 400px; border-radius: 8px;" />
                
                @if (!string.IsNullOrWhiteSpace(Product.Color))
                {
                    <span class="product-color" style="display: inline-block; margin-top: 15px;">@Product.Color</span>
                }
            </div>

            <div class="product-info">

                <span class="product-category">
                    @(Product.ProductSubcategory?.ProductCategory?.Name ?? "N/A")
                </span>

                <h2>@Product.Name</h2>

                <p class="product-description">
                    @(Product.ProductModel?.ProductModelProductDescriptionCultures
                        .FirstOrDefault()?.ProductDescription?.Description ?? "Sin descripción")
                </p>

                <div class="product-price">
                    RD$ @Product.ListPrice.ToString("N2")
                </div>

                <div class="product-actions">
                    <button class="btn-add" @onclick="() => Guardar(Product.ProductId)">
                        <i class="bi bi-cart"></i> Agregar al carrito
                    </button>
                </div>

            </div>

        </div>
    }
    else
    {
        <div class="product-empty">
            <p>Cargando producto...</p>
        </div>
    }

</div>

@code {
    [Parameter]
    public int ProductId { get; set; }

    private Product? Product;

    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;

        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        }

        var productos = await productService.GetList(p => p.ProductId == ProductId);
        Product = productos.FirstOrDefault();
    }

    private async Task Guardar(int productId)
    {
        try
        {
            await shoppingCartItemService.Guardar(
            new ShoppingCartItem
            {
                ShoppingCartId = UserEmail,
                Quantity = 1,
                ProductId = productId,
                DateCreated = DateTime.Now,
                ModifiedDate = DateTime.Now
            });

            toastService.ShowSuccess("Producto anadido al carrito");
        }
        catch (Exception ex)
        {
            toastService.ShowError("Error al agregar producto");
            Console.WriteLine(ex.Message);
        }
    }

    private string ResolverRutaImagen(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return "https://www.svgrepo.com/show/486796/product-management.svg";

        if (valor.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            valor.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            valor.StartsWith("data:image", StringComparison.OrdinalIgnoreCase) ||
            valor.StartsWith("/"))
        {
            return valor;
        }

        return $"/uploads/products/{valor}";
    }

    private void GoBack() => navigationManager.NavigateTo("/Sales");
}