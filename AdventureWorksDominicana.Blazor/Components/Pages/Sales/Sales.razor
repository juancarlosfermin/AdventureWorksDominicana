@page "/Sales/"

@attribute [Authorize(Roles = "Customer, Admin")]
@rendermode InteractiveServer

@inject ProductService productService
@inject ShoppingCartItemService shoppingCartItemService
@inject ToastService toastService
@inject NavigationManager navigationManager
@inject AuthenticationStateProvider authenticationStateProvider;

<PageTitle>SalesOrderHeader Index</PageTitle>
<div class="">
    <div class="sale-container">
        @*Header*@
        <div class="sale-header">
            <div class="sale-header-logo">
                <img src="/AdventureLogo.png" alt="AdventureWorksDominicana Logo" />
                <h4 class="card-title">AdventureWorksDominicana</h4>
            </div>
            <div class="sale-header-actions">
                <a href="Orders">Orders</a>
                <a href="ShoppingCart" class="btn btn-primary shopping-cart-container">
                    <i class="bi bi-cart"></i>
                    <span>@shoppingCount</span>
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="sale-input">
                <div class="input-group">
                    <input class="form-control" placeholder="buscar producto" @oninput="Buscar" />
                    <i class="btn btn-primary bi bi-search"></i>
                </div>
                <div class="input-group">
                    <select class="form-select">
                        <option>Por Categoria</option>
                    </select>
                    <i class="btn btn-primary bi bi-filter"></i>
                </div>
            </div>
            <div class="sale-products">
                @foreach (var p in PagedProducts)
                {
                    <div class="sale-product-card">
                        <div class="sale-product-img">
                            <img src="https://www.svgrepo.com/show/486796/product-management.svg" alt="Product Image" />
                            <span>@p.Color</span>
                        </div>
                        <div class="sale-product-info">
                            <span>@(p.ProductSubcategory?.ProductCategory?.Name ?? "N/A")</span>
                            <div class="sale-product-name">
                                <p>@p.Name</p>
                            </div>
                            <div class="sale-product-description">
                                <p>@(p.ProductModel?.ProductModelProductDescriptionCultures.FirstOrDefault()?.ProductDescription?.Description ?? "N/A")</p>
                            </div>
                            <div class="sale-product-price">
                                <span>RD$ @p.ListPrice.ToString("N2")</span>
                            </div>
                            <button type="button" @onclick="() => Guardar(p.ProductId)">
                                <i class="bi bi-cart"></i>
                                <span>Añadir al Carrito</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
            <div class="pagination">
                <i class="bi bi-arrow-left" @onclick="PaginaAnterior"></i>
                <span>@CurrentPage</span>
                <span>/</span>
                <span>@TotalPaginas</span>
                <i class="bi bi-arrow-right" @onclick="PaginaSiguiente"></i>
            </div>
        </div>
    </div>
</div>
@code {
    private List<Product> ProductList = new List<Product>();
    private int shoppingCount = 0;
    private string Filtro = string.Empty, ValorFiltro = string.Empty;
    private List<Product> PagedProducts = new List<Product>();

    private int CurrentPage = 1;
    private int PageSize = 12;
    private int TotalPaginas => (int)Math.Ceiling((double)ProductList.Count / PageSize);

    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Busca el usuario logeado
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;
        
        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        }

        ProductList = await productService.GetList(p => true);
        ActualizarVista();
        await CountProductsShopping();
    }

    private async Task CountProductsShopping()
    {
        var productsShoppingList = await shoppingCartItemService.GetList(s => s.ShoppingCartId.Trim().ToLower().Equals(UserEmail));
        shoppingCount = productsShoppingList.Count();
    }

    private async Task Guardar(int productId)
    {
        try
        {
            var creado = await shoppingCartItemService.Guardar(
            new ShoppingCartItem
            {
                ShoppingCartId = UserEmail,
                Quantity = 1,
                ProductId = productId,
                DateCreated = DateTime.Now,
                ModifiedDate = DateTime.Now
            });
            toastService.ShowSuccess("Producto añadido al carrito");
            await CountProductsShopping();
        }
        catch (Exception ex)
        {
            toastService.ShowSuccess("Producto no pudo ser añadido al carrito");
            Console.WriteLine(ex.Message);
        }
    }

    private void ActualizarVista()
    {
        PagedProducts = ProductList
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void PaginaSiguiente()
    {
        if (CurrentPage < TotalPaginas)
        {
            CurrentPage++;
            ActualizarVista();
        }
    }

    private void PaginaAnterior()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            ActualizarVista();
        }
    }

    private async Task Buscar(ChangeEventArgs e)
    {
        var value = e?.Value?.ToString();
        Expression<Func<Product, bool>> criterio = e => true;
        if (value?.Trim() != "")
        {
            criterio = criterio.And(e => e.Name.ToLower().Contains(value.ToLower()) || e.ProductSubcategory.ProductCategory.Name.ToLower().Contains(value.ToLower()));
        }
        ProductList = await productService.GetList(criterio);
        ActualizarVista();
    }
}