@page "/ShoppingCart/desuso"

@rendermode InteractiveServer

@inject ShoppingCartItemService shoppingCartItemService
@inject SalesOrderHeaderService salesOrderHeaderService
@inject AddressService addressService
@inject SalesTerritoryService salesTerritoryService
@inject CustomerService customerService
@inject CreditCardService creditCardService
@inject ShipMethodService shipMethodService
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject AuthenticationStateProvider authenticationStateProvider;

<PageTitle>ShoppingCart</PageTitle>

<div class="">
    <div class="shopping-container">
        @*Header*@
        <div class="shopping-header">
            <div class="shopping-header-logo">
                <i class="btn btn-primary bi bi-arrow-left" @onclick="GoToSale"></i>
                <img src="/AdventureLogo.png" alt="AdventureWorksDominicana Logo" />
                <h4 class="card-title">ShoppingCart</h4>
            </div>
        </div>
        <div class="shopping-body">
            @if (ShoppingCartItemList.Any())
            {
                <div class="shopping-products">
                    @foreach (var s in ShoppingCartItemList)
                    {
                        <div class="shopping-product-card">
                            <div class="shopping-product-img">
                                <img src="https://www.svgrepo.com/show/486796/product-management.svg" alt="Product Image" />
                                <span>@s.Product.Color</span>
                            </div>
                            <div class="shopping-product-info">
                                <div class="shopping-product-header">
                                    <span>@(s.Product.ProductSubcategory?.ProductCategory?.Name ?? "N/A")</span>
                                    <i class="btn btn-danger bi bi-trash" @onclick="() => DeleteItemCart(s.ShoppingCartItemId)"></i>
                                </div>
                                <div>
                                    <p>@s.Product.Name</p>
                                </div>
                                <div class="quantity-product-action">
                                    <button class="bi bi-dash" @onclick="() => MinusQuentity(s.ShoppingCartItemId)"></button>
                                    <span>@s.Quantity</span>
                                    <button class="bi bi-plus" @onclick="() => SumQuentity(s.ShoppingCartItemId)"></button>
                                </div>
                                <div>
                                    <span>RD$ @s.Product.ListPrice.ToString("N2")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="balance-general">
                    <p>Contabilidad</p>
                    <hr />
                    <div>
                        <span>Impuestos:</span>
                        <span>RD$@taxes.ToString("N2")</span>
                        <span>Flete:</span>
                        <span>RD$@freight.ToString("N2")</span>
                        <span>Descuento:</span>
                        <span>RD$@discountPct.ToString("N2")</span>
                        <span>Subtotal:</span>
                        <span>RD$@subtotal.ToString("N2")</span>
                        <span>Total:</span>
                        <span>RD$@total.ToString("N2")</span>
                    </div>
                    @if (addressId != 0 && shipMethodId != 0)
                    {
                        <button @onclick="SaveOrder">Confirmar Orden</button>
                    }
                    <button @onclick="() => showModal = true">Realizar Checkout</button>
                </div>
            }
            else
            {
                <div class="cart-empty">
                    <img src="/EmptyCart.png" alt="EmptyCart" />
                    <h3>El carrito est&aacute; vac&iacute;o</h3>
                </div>
            }
        </div>
        @if (showModal)
        {
            <div class="backdrop-modal" @onclick="() => showModal = false">
                <div class="modal-content" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h1>Realización de Checkout</h1>
                    </div>
                    <div class="modal-body">
                        <select @bind="territoryId">
                            <option value=0>Seleccione un Territorio</option>
                            @foreach (var t in SalesTerritoriesList)
                            {
                                <option value="@t.TerritoryId">@t.Name</option>
                            }
                        </select>
                        <select @bind="addressId">
                            <option value=0>Seleccione una direcciones de envio</option>
                            @foreach (var a in AddressesList)
                            {
                                <option value="@a.AddressId">@a.AddressLine1 - @a.City - @a.StateProvince.Name</option>
                            }
                        </select>
                        <select @bind="shipMethodId">
                            <option value=0>Seleccione una metodo de envio</option>
                            @foreach (var s in ShipMethodsList)
                            {
                                <option value="@s.ShipMethodId">@s.Name</option>
                            }
                        </select>
                        <select @bind="customerId">
                            <option value=0>Seleccione el cliente</option>
                            @foreach (var c in CustomersList)
                            {
                                <option value="@c.CustomerId">@c.Person?.FirstName</option>
                            }
                        </select>
                        <input type="text" placeholder="Tarjeta Credito" />
                    </div>

                    <div class="modal-footer d-flex justify-content-center">
                        <button class="btn btn-primary" @onclick="setCompletedCheckout">Guardar</button>
                    </div>
                </div>
            </div>
        }
    </div>
    
</div>

@code {
    private List<ShoppingCartItem> ShoppingCartItemList = new List<ShoppingCartItem>();
    private List<Address> AddressesList = new List<Address>();
    private List<Customer> CustomersList = new List<Customer>();
    private List<SalesTerritory> SalesTerritoriesList = new List<SalesTerritory>();
    private List<CreditCard> CreditCardsList = new List<CreditCard>();
    private List<ShipMethod> ShipMethodsList = new List<ShipMethod>();

    private decimal taxes = 0.0m, freight = 0.0m, discountPct = 0.0m, subtotal = 0.0m, total = 0.0m;
    private const decimal GrToLb = 453.59237m, KgToLb = 2.20462262m;
    private int territoryId, addressId, customerId, creditCardId, shipMethodId;
    private bool showModal = false;

    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }
    private List<Customer> userCurrent = new List<Customer>();

    protected override async Task OnInitializedAsync()
    {
        // Busca el usuario logeado
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;

        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        }

        // Solo trae los items del usuario logeado
        ShoppingCartItemList = await shoppingCartItemService.GetList(s => s.ShoppingCartId.Trim().ToLower().Equals(UserEmail));
        userCurrent = await customerService.GetList(u => u.Person.EmailAddresses.Any(p => p.EmailAddress1.Trim().ToLower().Equals(UserEmail)));
        AddressesList = await addressService.GetList(s => true);
        CustomersList = await customerService.GetList(s => true);
        SalesTerritoriesList = await salesTerritoryService.GetList(s => true);
        CreditCardsList = await creditCardService.GetList(s => true);
        ShipMethodsList = await shipMethodService.GetList(s => true);
        GetBalance();
    }

    private void GoToSale() => navigationManager.NavigateTo("/Sales");

    private void GetBalance()
    {
        GetDiscountPct();
        GetSubtotal();
        GetTaxes();
        GetFreight();
        GetTotal();
    }

    private void GetTaxes() => taxes = AddressesList.FirstOrDefault(t => t.AddressId == addressId)?.StateProvince?.SalesTaxRates?.FirstOrDefault()?.TaxRate ?? 0;

    private void GetFreight()
    {
        var shipMethod = ShipMethodsList.FirstOrDefault(f => f.ShipMethodId == shipMethodId);
        var shipBase = shipMethod?.ShipBase ?? 0;
        var shipRate = shipMethod?.ShipRate ?? 0;
        decimal weight = 0;
        foreach (var m in ShoppingCartItemList)
        {
            if (m?.Product?.WeightUnitMeasureCode?.Trim() == "G")
                weight += ((m?.Product?.Weight ?? 0) * (m?.Quantity ?? 0)) / 453.59237m;
            else if (m?.Product?.WeightUnitMeasureCode?.Trim() == "KG")
                weight += ((m?.Product?.Weight ?? 0) * (m?.Quantity ?? 0)) * KgToLb;
            else
                weight += (m?.Product?.Weight ?? 0) * (m?.Quantity ?? 0);
        }
        freight = shipBase + (weight * shipRate);
    }

    private void GetTotal() => total = (freight + subtotal + (subtotal * taxes)) - discountPct;

    private void GetSubtotal()
    {
        subtotal = 0;
        foreach (var p in ShoppingCartItemList)
            subtotal += (p?.Product?.ListPrice ?? 0) * (p?.Quantity ?? 0);
    }

    private void GetDiscountPct()
    {
        discountPct = 0;
        foreach (var p in ShoppingCartItemList)
        {
            var offer = p.Product?.SpecialOfferProducts?
                .Select(x => x.SpecialOffer)
                .Where(o => o.StartDate <= DateTime.Now && o.EndDate >= DateTime.Now)
                .OrderByDescending(o => o.DiscountPct)
                .FirstOrDefault();
            var discount = offer?.DiscountPct ?? 0;
            var totalProduct = (p?.Product?.ListPrice ?? 0) * (p?.Quantity ?? 0);
            discountPct += discount * totalProduct;
        }
    }

    private async Task SumQuentity(int itemId)
    {
        var item = ShoppingCartItemList.FirstOrDefault(x => x.ShoppingCartItemId == itemId);
        if (item != null)
        {
            item.Quantity += 1;
            await shoppingCartItemService.Guardar(item);
            GetBalance();
        }
    }

    private async Task MinusQuentity(int itemId)
    {
        var item = ShoppingCartItemList.FirstOrDefault(x => x.ShoppingCartItemId == itemId);
        if (item != null)
        {
            if (item.Quantity != 1)
                item.Quantity -= 1;
            await shoppingCartItemService.Guardar(item);
            GetBalance();
        }
    }

    private void setCompletedCheckout()
    {
        GetBalance();
        showModal = false;
    }

    private async Task RefreshShoppingCart(){
        ShoppingCartItemList = await shoppingCartItemService.GetList(s => s.ShoppingCartId.Trim().ToLower().Equals(UserEmail));
        GetBalance();
    }

    private async Task DeleteItemCart(int itemId)
    {
        try
        {
            var eliminated = await shoppingCartItemService.Eliminar(itemId);
            toastService.ShowSuccess("Producto eliminado correctamente");
            await RefreshShoppingCart();
        }catch(Exception ex)
        {
            toastService.ShowSuccess("Producto no pudo ser eliminado correctamente");
            Console.Write(ex.Message);
        }
    }

    private async Task SaveOrder()
    {
        SalesOrderHeader newOrder = new SalesOrderHeader
        {
            RevisionNumber = 0,
            OrderDate = DateTime.Now,
            DueDate = DateTime.Now.AddDays(10),
            ShipDate = null,
            Status = 1,
            OnlineOrderFlag = true,
            SalesOrderNumber = $"SO{DateTime.Now:yyyyMMddHHmmss}{Random.Shared.Next(1000, 9999)}",
            PurchaseOrderNumber = $"PO{DateTime.Now:yyyyMMddHHmmss}{Random.Shared.Next(1000, 9999)}",
            AccountNumber = null,
            CustomerId = userCurrent[0].CustomerId,
            SalesPersonId = null,
            TerritoryId = territoryId,
            BillToAddressId = addressId,
            ShipToAddressId = addressId,
            ShipMethodId = shipMethodId,
            CreditCardId = null,
            CreditCardApprovalCode = null,
            CurrencyRateId = null,
            SubTotal = subtotal,
            TaxAmt = taxes,
            Freight = freight,
            TotalDue = total,
            Comment = null,
            Rowguid = Guid.NewGuid(),
            ModifiedDate = DateTime.Now
        };
        // Obtener el SpecialOffer "No Discount" (generalmente ID = 1)
        const int noDiscountSpecialOfferId = 1;

        foreach (var s in ShoppingCartItemList)
        {
            var offer = s.Product?.SpecialOfferProducts?
                .Select(x => x.SpecialOffer)
                .Where(o => o.StartDate <= DateTime.Now && o.EndDate >= DateTime.Now)
                .OrderByDescending(o => o.DiscountPct)
                .FirstOrDefault();

            // Asignar SpecialOfferId válido (1 si no hay oferta)
            var specialOfferId = offer?.SpecialOfferId ?? noDiscountSpecialOfferId;
            var discountPct = offer?.DiscountPct ?? 0;
            var unitPrice = s?.Product?.ListPrice ?? 0;
            var quantity = s?.Quantity ?? 0;
            var unitPriceDiscount = unitPrice * discountPct;
            var lineTotal = quantity * (unitPrice - unitPriceDiscount);

            newOrder.SalesOrderDetails.Add(new SalesOrderDetail
            {
                CarrierTrackingNumber = null,
                OrderQty = Convert.ToInt16(quantity),
                ProductId = s.ProductId,
                SpecialOfferId = specialOfferId,
                UnitPrice = unitPrice,
                UnitPriceDiscount = unitPriceDiscount,
                LineTotal = lineTotal,
                Rowguid = Guid.NewGuid(),
                ModifiedDate = DateTime.Now
            });
        }
        try
        {
            var orderCreated = await salesOrderHeaderService.Guardar(newOrder);
            toastService.ShowSuccess("Se creo la orden correctamente");
            navigationManager.NavigateTo("Orders");
            foreach (var s in ShoppingCartItemList)
            {
                await shoppingCartItemService.Eliminar(s.ShoppingCartItemId);
            }
        }
        catch (Exception ex)
        {
            toastService.ShowSuccess("No se creo la orden correctamente");
            //Console.WriteLine(ex.Message);
        }
    }
}