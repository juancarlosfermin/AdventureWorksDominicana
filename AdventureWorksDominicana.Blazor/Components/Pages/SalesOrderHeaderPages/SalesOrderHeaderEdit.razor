@page "/SalesOrderHeader/Edit/{SalesOrderId:int}"
@rendermode InteractiveServer
@inject SalesOrderHeaderService salesOrderHeaderService
@inject CustomerService customerService
@inject SalesTerritoryService salesTerritoryService
@inject SalesPersonService salesPersonService
@inject AddressService addressService
@inject ShipMethodService shipMethodService
@inject CurrencyRateService currencyRateService
@inject CreditCardService creditCardService
@inject SpecialOfferProductService specialOfferProductService
@inject ToastService toastService;
@inject NavigationManager navigationManager

<PageTitle>SalesOrderHeader Edit</PageTitle>
<EditForm Model="@SalesOrderHeader" OnValidSubmit="Update">
    <DataAnnotationsValidator />
    <div class="container">
        <div class="card shadow-lg">
            @*Header*@
            <div class="card-header">
                <h4 class="card-title">Edici&oacute;n de Venta</h4>
            </div>
        
            <div class="card-body">
                @if (!showHeader)
                {
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha Vencimineto</label>
                            <InputDate class="form-control" @bind-Value="SalesOrderHeader.DueDate" />
                            <ValidationMessage For="() => SalesOrderHeader.DueDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Fecha de Env&iacute;o</label>
                            <InputDate class="form-control" @bind-Value="SalesOrderHeader.ShipDate" />
                            <ValidationMessage For="() => SalesOrderHeader.ShipDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Estado</label>
                            <InputSelect @bind-Value="SalesOrderHeader.Status" class="form-select">
                                <option value="">
                                    @((SalesOrderHeader.Status == 1) ? "En Proceso" :
                                      (SalesOrderHeader.Status == 2) ? "Enviada" :
                                      (SalesOrderHeader.Status == 3) ? "Cancelada" : "-- Seleccionar --")
                                </option>
                                <option value=1>En Proceso</option>
                                <option value=2>Enviada</option>
                                <option value=3>Cancelada</option>
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.Status" />
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Nombre del Cliente</label>
                            <InputSelect @bind-Value="SalesOrderHeader.CustomerId" class="form-select">
                                <option value="0">Seleccione un Cliente</option>
                                @foreach (var c in CustomersList)
                                {
                                    <option value="@c.CustomerId">@(c.PersonId != null ? $"{c.Person?.FirstName ?? "N/A"} {c.Person?.LastName ?? "N/A"}" : c.Store?.Name ?? "N/A")</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.CustomerId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Nombre del Vendedor</label>
                            <InputSelect @bind-Value="SalesOrderHeader.SalesPersonId" class="form-select">
                                <option value="0">Seleccione un Vendedor</option>
                                @foreach (var v in SalesPeopleList)
                                {
                                    <option value="@v.BusinessEntityId">@v.BusinessEntity.BusinessEntity.FirstName @v.BusinessEntity.BusinessEntity.LastName</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.SalesPersonId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Nombre del Territorio</label>
                            <InputSelect @bind-Value="SalesOrderHeader.TerritoryId" class="form-select">
                                <option value="0">Seleccione un Territorio</option>
                                @foreach (var t in SalesTerritoriesList)
                                {
                                    <option value="@t.TerritoryId">@t.Name - @t.CountryRegionCode - @t.Group</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.TerritoryId" />
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Direcci&oacute;n de Factura</label>
                            <InputSelect @bind-Value="SalesOrderHeader.BillToAddressId" class="form-select">
                                <option value="0">Seleccione Direcci&oacute;n de Factura</option>
                                @foreach (var d in AddressesList)
                                {
                                    <option value="@d.AddressId">@d.AddressLine1,@d.City, @d.StateProvince.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.BillToAddressId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Direcci&oacute;n de Env&iacute;o</label>
                            <InputSelect @bind-Value="SalesOrderHeader.ShipToAddressId" @bind-Value:after="TaxesCalculate" class="form-select">
                                <option value="0">Seleccione Direcci&oacute;n de Env&iacute;o</option>
                                @foreach (var d in AddressesList)
                                {
                                    <option value="@d.AddressId">@d.AddressLine1,@d.City, @d.StateProvince.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.ShipToAddressId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">M&eacute;todo de Env&iacute;o</label>
                            <InputSelect @bind-Value="SalesOrderHeader.ShipMethodId" @bind-Value:after="Total" class="form-select">
                                <option value="0">Seleccione M&eacute;todo de Env&iacute;o</option>
                                @foreach (var m in ShipMethodsList)
                                {
                                    <option value="@m.ShipMethodId">@m.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.ShipMethodId" />
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Tarjeta de Cr&eacute;dito</label>
                            <InputSelect @bind-Value="SalesOrderHeader.CreditCardId" class="form-select">
                                <option value="0">Seleccione tarjeta de cr&eacute;dito</option>
                                @foreach (var c in CreditCardsList)
                                {
                                    <option value="@c.CreditCardId">@c.CardType - @c.CardNumber</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.CreditCardId" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">C&oacute;digo de autorizaci&oacute;n de la tarjeta</label>
                            <InputText class="form-control" @bind-Value="SalesOrderHeader.CreditCardApprovalCode" />
                            <ValidationMessage For="() => SalesOrderHeader.CreditCardApprovalCode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Tasa de Cambio</label>
                            <InputSelect @bind-Value="SalesOrderHeader.CurrencyRateId" @bind-Value:after="Total" class="form-select">
                                <option value="">USD</option>
                                @foreach (var r in CurrencyRatesList)
                                {
                                    <option value="@r.CurrencyRateId">@r.FromCurrencyCode - @r.ToCurrencyCode</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => SalesOrderHeader.CurrencyRateId" />
                        </div>
                    </div>
                }
                <div class="border border-success p-3 mb-3 mt-2">
                    <div class="d-flex justify-content-between">
                        <h3>Lista de Productos</h3>
                        <div class="col-md-2">
                            <i class="btn btn-outline-info bi-arrow-down" @onclick="ChangeShowHeader"></i>
                        </div>
                    </div>
                    @if (showHeader)
                    {
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Nombre del Producto</label>
                                <InputSelect @bind-Value="SalesOrderDetail.ProductId" class="form-select">
                                    <option value="0">Seleccione un Producto</option>
                                    @foreach (var p in SpecialOfferProductsList)
                                    {
                                        <option value="@p.ProductId">@p.Product.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => SalesOrderDetail.ProductId" />
                            </div>
                            <div class="col-md-2 fw-bold">
                                <label class="form-label">Precio</label>
                                <InputNumber @bind-Value="SalesOrderDetail.UnitPrice" class="form-control" />
                                <ValidationMessage For="() => SalesOrderDetail.UnitPrice" />
                            </div>
                            <div class="col-md-2 fw-bold">
                                <label class="form-label">Cantidad</label>
                                <InputNumber @bind-Value="SalesOrderDetail.OrderQty" class="form-control" />
                                <ValidationMessage For="() => SalesOrderDetail.OrderQty" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label"></label>
                                <button type="button" class="form-control btn btn-primary bi bi-plus g-3 mt-2" @onclick="AddDetail">Agregar</button>
                            </div>
                            <div class="row">
                                @if (!string.IsNullOrWhiteSpace(message))
                                {
                                    <div class="mt-1 alert alert-danger col-4">@message</div>
                                }
                            </div>
                            
                        </div>
                        @if (SalesOrderHeader.SalesOrderDetails.Any())
                        {
                            <div class="mt-1 table-responsive">
                                <QuickGrid Items="SalesOrderHeader.SalesOrderDetails.AsQueryable()" Class="table table-bordered table-striped table-hover" Pagination="pages">
                                    <TemplateColumn Context="nombre" Title="Nombre">
                                        @(SpecialOfferProductsList.FirstOrDefault(s => s.ProductId == nombre.ProductId)?.Product.Name ?? "N/A")
                                    </TemplateColumn>
                                    <PropertyColumn Property="@(a => a.OrderQty)" Title="Cantidad" Sortable="true" />
                                    <PropertyColumn Property="@(d => d.UnitPriceDiscount)" Format="P0" Title="Descuento %" Sortable="true" />
                                    <PropertyColumn Property="@(u => u.UnitPrice)" Title="Precio Unitario" Format="N2" Sortable="true" />
                                    <PropertyColumn Property="@(t => t.LineTotal)" Title="Total" Format="N2" Sortable="true" />
                                    <TemplateColumn Context="option" Title="Opci&oacute;n">
                                        <button type="button" class="btn btn-outline-dark btn-sm" @onclick="() => DeleteDetails(option)">Eliminar</button>
                                    </TemplateColumn>
                                </QuickGrid>
                                <div class="d-flex justify-content-end">
                                    <Paginator State="pages" />
                                </div>
                            </div>
                        }
                        
                    }
                    
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Subtotal</label>
                        <label class="form-control">@SalesOrderHeader.SubTotal.ToString("N2")</label>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Impuestos</label>
                        <label class="form-control">@SalesOrderHeader.TaxAmt.ToString("N2")</label>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Monto Flete</label>
                        <label class="form-control">@SalesOrderHeader.Freight.ToString("N2")</label>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Monto Total</label>
                        <label class="form-control">@SalesOrderHeader.TotalDue.ToString("N2")</label>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-center gap-2">
                <a href="SalesOrderHeader/Index" class="btn btn-secondary d-flex gap-1">
                    <i class="bi bi-arrow-left"></i>
                    <span>Volver</span>
                </a>
                <button class="btn btn-primary">
                    <i class="bi bi-floppy me-1"></i> Guardar
                </button>
                <button type="button" class="btn btn-danger bi bi-trash" @onclick="DeleteOrder">Eliminar</button>
            </div>
        </div>
    </div>
</EditForm>

@if (showLoading)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-body text-center p-5">
                    <div class="spinner-border text-primary" role="status" style="width: 3.5rem; height: 3.5rem;">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <h4 class="mt-4 fw-bold">Procesando Venta</h4>
                    <p class="text-muted mb-0">Estamos actualizando el inventario y registrando los datos en AdventureWorksDominicana.</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int SalesOrderId { get; set; }

    //SalesOrderHeader Data
    private SalesOrderHeader SalesOrderHeader = new SalesOrderHeader();
    private List<Customer> CustomersList = new List<Customer>();
    private List<SalesTerritory> SalesTerritoriesList = new List<SalesTerritory>();
    private List<SalesPerson> SalesPeopleList = new List<SalesPerson>();
    private List<Address> AddressesList = new List<Address>();
    private List<ShipMethod> ShipMethodsList = new List<ShipMethod>();
    private List<CreditCard> CreditCardsList = new List<CreditCard>();
    private List<CurrencyRate> CurrencyRatesList = new List<CurrencyRate>();

    //SalesOrderDetail Data
    private SalesOrderDetail SalesOrderDetail = new SalesOrderDetail();
    private List<SpecialOfferProduct> SpecialOfferProductsList = new List<SpecialOfferProduct>();

    private bool showHeader = false, showLoading = true;
    private PaginationState pages = new PaginationState { ItemsPerPage = 4 };
    private string message = string.Empty;

    const decimal G_TO_LB = 453.59237m, KG_TO_LB = 2.20462262m;

    public void ChangeShowHeader() { showHeader = !showHeader; }

    protected override async Task OnInitializedAsync()
    {
        SalesOrderHeader = await salesOrderHeaderService.Buscar(SalesOrderId);
        var customersTask = customerService.GetList(c => true);
        var peopleTask = salesPersonService.GetList(c => true);
        var territoriesTask = salesTerritoryService.GetList(c => true);
        var addressesTask = addressService.GetList(c => true);
        var shipMethodsTask = shipMethodService.GetList(c => true);
        var cardsTask = creditCardService.GetList(c => true);
        var ratesTask = currencyRateService.GetList(c => true);
        var specialOfferTask = specialOfferProductService.GetList(c => true);

        await Task.WhenAll(customersTask, peopleTask, territoriesTask, addressesTask,
                           shipMethodsTask, cardsTask, ratesTask, specialOfferTask);
        showLoading = false;
        CustomersList = customersTask.Result;
        SalesPeopleList = peopleTask.Result;
        SalesTerritoriesList = territoriesTask.Result;
        AddressesList = addressesTask.Result;
        ShipMethodsList = shipMethodsTask.Result;
        CreditCardsList = cardsTask.Result;
        CurrencyRatesList = ratesTask.Result;
        SpecialOfferProductsList = specialOfferTask.Result;
        Total();
    }

    private void AddDetail()
    {
        if (SalesOrderDetail.ProductId == 0)
        {
            message = "Debe de Seleccionar un Producto";
            return;
        }
        var productData = SpecialOfferProductsList.FirstOrDefault(p => p.ProductId == SalesOrderDetail.ProductId)?.Product;
        var stockDisponible = productData?.ProductInventories.Sum(i => i.Quantity) ?? 0;
        if (SalesOrderDetail.OrderQty > stockDisponible)
        {
            message = $"Cantidad insuficiente. Solo hay {stockDisponible} unidades en inventario.";
            return;
        }
        else if (SalesOrderDetail.UnitPrice < 1)
        {
            message = "Debe de establecer un precio";
            return;
        }
        else if (SalesOrderDetail.OrderQty < 1)
        {
            message = "Debe de establecer una Cantidad";
            return;
        }
        else if (SalesOrderHeader.SalesOrderDetails.Any(p => p.ProductId == SalesOrderDetail.ProductId))
        {
            message = "No se aceptan productos duplicados";
            return;
        }
        else
            message = "";
        SalesOrderHeader.SalesOrderDetails.Add(
            new SalesOrderDetail
            {
                CarrierTrackingNumber = $"TRK-{Random.Shared.Next(100000, 999999)}",
                OrderQty = SalesOrderDetail.OrderQty,
                ProductId = SalesOrderDetail.ProductId,
                SpecialOfferId = SpecialOfferProductsList.First(o => o.ProductId == SalesOrderDetail.ProductId).SpecialOfferId,
                UnitPrice = SalesOrderDetail.UnitPrice,
                UnitPriceDiscount = SpecialOfferProductsList.First(o => o.ProductId == SalesOrderDetail.ProductId).SpecialOffer.DiscountPct,
                LineTotal = SalesOrderDetail.OrderQty * (SalesOrderDetail.UnitPrice - (SalesOrderDetail.UnitPrice * SpecialOfferProductsList.First(o => o.ProductId == SalesOrderDetail.ProductId).SpecialOffer.DiscountPct)),
                Rowguid = Guid.NewGuid(),
                ModifiedDate = DateTime.Now
            }
        );
        Total();
        SalesOrderDetail = new();
    }

    void DeleteDetails(SalesOrderDetail sale)
    {
        SalesOrderHeader.SalesOrderDetails.Remove(sale);
        SalesOrderDetail = sale;
        toastService.ShowSuccess("Producto eliminado correctamente");
        Total();
    }

    private void TaxesCalculate() 
    { 
        SalesOrderHeader.TaxAmt = AddressesList.First(t => t.AddressId == SalesOrderHeader.ShipToAddressId).StateProvince.SalesTaxRates.First().TaxRate * SalesOrderHeader.SubTotal; 
    }

    private void FreightCalculate()
    {
        var shipMethod = ShipMethodsList.FirstOrDefault(s => s.ShipMethodId == SalesOrderHeader.ShipMethodId);
        decimal totalPeso = 0;
        foreach (var detalle in SalesOrderHeader.SalesOrderDetails)
        {
            var product = (SpecialOfferProductsList.FirstOrDefault(s => s.ProductId == detalle.ProductId)?.Product);
            if (product?.WeightUnitMeasureCode?.Trim() == "G")
                totalPeso += ((product?.Weight ?? 0) * detalle.OrderQty) / G_TO_LB;
            else if (product?.WeightUnitMeasureCode?.Trim() == "KG")
                totalPeso += ((product?.Weight ?? 0) * detalle.OrderQty) * KG_TO_LB;
            else
                totalPeso += (product?.Weight ?? 0) * detalle.OrderQty;
        }
        SalesOrderHeader.Freight = (shipMethod?.ShipBase ?? 0) + (totalPeso * (shipMethod?.ShipRate ?? 0));
    }

    private void SubtotalCalculate()
    {
        SalesOrderHeader.SubTotal = SalesOrderHeader.SalesOrderDetails.Sum(t => t.LineTotal);
    }

    private void TotalCalculate() 
    { 
        SalesOrderHeader.TotalDue = SalesOrderHeader.SubTotal + SalesOrderHeader.TaxAmt + SalesOrderHeader.Freight; 
    }

    private void Total()
    {
        SubtotalCalculate();
        TaxesCalculate();
        FreightCalculate();
        var tasa = CurrencyRatesList.FirstOrDefault(c => c.CurrencyRateId == SalesOrderHeader.CurrencyRateId)?.EndOfDayRate ?? 1;
        SalesOrderHeader.SubTotal *= tasa;
        SalesOrderHeader.TaxAmt *= tasa;
        SalesOrderHeader.Freight *= tasa;
        TotalCalculate();
    }

    private void ReturnOriginCurrencyRate()
    {
        var tasa = CurrencyRatesList.FirstOrDefault(c => c.CurrencyRateId == SalesOrderHeader.CurrencyRateId)?.EndOfDayRate ?? 1;
        SalesOrderHeader.SubTotal /= tasa;
        SalesOrderHeader.TaxAmt /= tasa;
        SalesOrderHeader.Freight /= tasa;
    }

    private async Task Update()
    {
        if (SalesOrderHeader.ShipDate.HasValue && SalesOrderHeader.DueDate.HasValue && (SalesOrderHeader.ShipDate.Value.Date > SalesOrderHeader.DueDate.Value.Date || SalesOrderHeader.ShipDate < SalesOrderHeader.OrderDate))
        {
            toastService.ShowWarning("La fecha de envío no debe de ser mayor a la fecha de vencimiento ni menor a la de creación de la orden.");
            return;
        }
        else if (SalesOrderHeader.BillToAddressId == SalesOrderHeader.ShipToAddressId)
        {
            toastService.ShowError("Las direcciones de factura y envío no deben de ser iguales");
            return;
        }
        else if (!SalesOrderHeader.SalesOrderDetails.Any())
        {
            toastService.ShowWarning("Debe de guardar al menos un producto");
            return;
        }
        SalesOrderHeader.AccountNumber = CustomersList.FirstOrDefault(c => c.CustomerId == SalesOrderHeader.CustomerId)?.AccountNumber;
        ReturnOriginCurrencyRate();
        try
        {
            var modificated = await salesOrderHeaderService.Guardar(SalesOrderHeader);
            toastService.ShowSuccess("Venta actualizada correctamente");
            navigationManager.NavigateTo("SalesOrderHeader/Index");
        }
        catch (Exception message)
        {
            toastService.ShowSuccess(message.Message);
        }

    }

    private async Task DeleteOrder()
    {
        var deleted = await salesOrderHeaderService.Eliminar(SalesOrderId);
        if (deleted)
        {
            toastService.ShowSuccess("Venta eliminada correctamente");
            navigationManager.NavigateTo("SalesOrderHeader/Index");
        }
        else
            toastService.ShowSuccess("Venta no pudo ser eliminada correctamente");
    }
}