@page "/SalesTerritory/Create"
@attribute [Authorize(Roles = "Admin")]

@inject SalesTerritoryService salesTerritoryService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@inject CountryRegionsService countryRegionsService;
@rendermode InteractiveServer

<div class="sales-territory-container">

    <!-- HEADER -->
    <div class="sales-territory-header">
        <div>
            <h3>Crear Territorio de Venta</h3>
            <span>Registro de nuevos territorios comerciales</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="sales-territory-form">
        <EditForm Model="SalesTerritory" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">

                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-geo"></i> Información General
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <input class="form-control" type="text" maxlength="50"
                               placeholder="Ej: Norteamérica - Este"
                               @bind-value="SalesTerritory.Name" />
                        <ValidationMessage For="(() => SalesTerritory.Name)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>País / Región</strong></label>
                        <select class="form-select" @bind="SalesTerritory.CountryRegionCode">
                            <option value="">— Seleccione —</option>
                            @foreach (var c in ListaCountryRegion)
                            {
                                <option value="@c.CountryRegionCode">@c.Name (@c.CountryRegionCode)</option>
                            }
                        </select>
                        <ValidationMessage For="(() => SalesTerritory.CountryRegionCode)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Grupo</strong></label>
                        <select class="form-select" @bind="SalesTerritory.Group">
                            <option value="">— Seleccione —</option>
                            <option value="Norteamerica">Norteamérica</option>
                            <option value="Europa">Europa</option>
                            <option value="Pacifico">Pacífico</option>
                            <option value="Asia">Asia</option>
                            <option value="Sudamerica">Sudamérica</option>
                            <option value="Centroamerica">Centroamérica</option>
                            <option value="Africa">África</option>
                            <option value="Medio Oriente">Medio Oriente</option>
                            <option value="Oceania">Oceanía</option>
                            <option value="Caribe">Caribe</option>
                        </select>
                        <ValidationMessage For="(() => SalesTerritory.Group)" />
                    </div>

                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/SalesTerritory/Index"> Volver</a>
                    <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
                </div>

            </div>
        </EditForm>
    </div>
</div>

@code {
    public List<CountryRegion> ListaCountryRegion { get; set; } = new List<CountryRegion>();
    public SalesTerritory SalesTerritory { get; set; } = new SalesTerritory();

    protected override async Task OnInitializedAsync()
    {
        ListaCountryRegion = await countryRegionsService.GetList(c => !c.CountryRegionCode.Equals(""));
        ListaCountryRegion = ListaCountryRegion.OrderBy(c => c.Name).ToList();
    }

    public async Task Guardar()
    {
        bool nombreDuplicado = await salesTerritoryService.BuscarDuplicado(SalesTerritory.Name, SalesTerritory.CountryRegionCode);
        if (nombreDuplicado)
        {
            toastService.ShowWarning("El nombre \"" + SalesTerritory.Name + "\" ya esta en uso en el pais/region.");
            return;
        }

        SalesTerritory.ModifiedDate = DateTime.Now;
        bool guardado = await salesTerritoryService.Guardar(SalesTerritory);
        if (guardado)
        {
            toastService.ShowSuccess("Sales territory creado exitosamente.");
            navigationManager.NavigateTo("/SalesTerritory/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar.");
        }
    }
}
