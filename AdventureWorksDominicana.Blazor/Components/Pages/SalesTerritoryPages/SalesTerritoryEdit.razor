@page "/SalesTerritory/Edit/{SalesTerritoryId:int}"
@attribute [Authorize(Roles = "Admin")]

@inject SalesTerritoryService salesTerritoryService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@inject CountryRegionsService countryRegionsService;
@rendermode InteractiveServer

<div class="product-container">

    <!-- HEADER -->
    <div class="product-header">
        <div>
            <h3>Modificar Territorio</h3>
            <span>Edición de territorios comerciales</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="product-form">
        <EditForm Model="SalesTerritory" OnValidSubmit="Modificar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN -->
                    <h5 class="section-title">
                        <i class="bi bi-geo"></i> Información General
                    </h5>

                    <!-- NOMBRE -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <input class="form-control"
                               type="text"
                               maxlength="50"
                               placeholder="Escriba el nombre..."
                               @bind-value="SalesTerritory.Name" />
                        <ValidationMessage For="(() => SalesTerritory.Name)" />
                    </div>

                    <!-- PAÍS -->
                    <div class="mb-3">
                        <label class="form-label"><strong>País / Región</strong></label>
                        <select class="form-select" @bind="SalesTerritory.CountryRegionCode">
                            <option value="">— Seleccione —</option>
                            @foreach (var countryRegion in ListaCountryRegion)
                            {
                                <option value="@countryRegion.CountryRegionCode">
                                    @countryRegion.Name (@countryRegion.CountryRegionCode)
                                </option>
                            }
                        </select>
                        <ValidationMessage For="(() => SalesTerritory.CountryRegionCode)" />
                    </div>

                    <!-- GRUPO -->
                    <div class="mb-3">
                        <label class="form-label"><strong>Grupo</strong></label>
                        <select class="form-select" @bind="SalesTerritory.Group">
                            <option value="">— Seleccione —</option>
                            <option value="Norteamerica">Norteamérica</option>
                            <option value="Europa">Europa</option>
                            <option value="Pacifico">Pacífico</option>
                            <option value="Asia">Asia</option>
                            <option value="Sudamerica">Sudamérica</option>
                            <option value="Centroamerica">Centroamérica</option>
                            <option value="Africa">África</option>
                            <option value="Medio Oriente">Medio Oriente</option>
                            <option value="Oceania">Oceanía</option>
                            <option value="Caribe">Caribe</option>
                        </select>
                        <ValidationMessage For="(() => SalesTerritory.Group)" />
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/SalesTerritory/Index">
                        Volver
                    </a>

                    <button class="btn btn-primary bi bi-floppy" type="submit">
                        Guardar
                    </button>

                    <button class="btn btn-danger bi bi-trash" type="button" @onclick="Eliminar">
                        Eliminar
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int SalesTerritoryId { get; set; }

    public List<CountryRegion> ListaCountryRegion { get; set; } = new List<CountryRegion>();
    public SalesTerritory SalesTerritory { get; set; } = new SalesTerritory();

    protected override async Task OnInitializedAsync()
    {
        SalesTerritory = await salesTerritoryService.Buscar(SalesTerritoryId);
        SalesTerritory.ModifiedDate = DateTime.Now;
        ListaCountryRegion = await countryRegionsService.GetList(c => !c.CountryRegionCode.Equals(""));
        ListaCountryRegion = ListaCountryRegion.OrderBy(c => c.Name).ToList();
    }

    public async Task Modificar()
    {
        bool nombreDuplicado = await salesTerritoryService.BuscarDuplicado(SalesTerritory.Name, SalesTerritory.CountryRegionCode, SalesTerritory.TerritoryId);
        if (nombreDuplicado)
        {
            toastService.ShowWarning("El nombre \"" + SalesTerritory.Name + "\" ya esta en uso en " + SalesTerritory.CountryRegionCode + ".");
            return;
        }

        bool modificado = await salesTerritoryService.Guardar(SalesTerritory);
        if (modificado)
        {
            toastService.ShowSuccess("Sales territory modificado exitosamente.");
            navigationManager.NavigateTo("/SalesTerritory/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al modificar.");
        }
    }

    public async Task Eliminar()
    {
        try
        {
            bool eliminado = await salesTerritoryService.Eliminar(SalesTerritory.TerritoryId);
            if (eliminado)
            {
                toastService.ShowSuccess("Territorio eliminado correctamente");
                navigationManager.NavigateTo("/SalesTerritory/Index");
            }
        }
        catch (InvalidOperationException ex)
        {
            toastService.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            toastService.ShowError("Error inesperado al eliminar");
        }
    }
}
