@page "/SalesTerritory/Index"
@attribute [Authorize(Roles = "Admin, SalesManager")]

@inject SalesTerritoryService salesTerritoryService;
@inject AuthenticationStateProvider authenticationStateProvider
@rendermode InteractiveServer

<div class="sales-territory-container">

    <!-- HEADER -->
    <div class="sales-territory-header">
        <div>
            <h3>Territorios de Venta</h3>
            <span>Gestión y consulta de territorios comerciales</span>
        </div>

        <a class="btn btn-primary" href="/SalesTerritory/Create">
            <i class="bi bi-plus-square"></i> Crear
        </a>
    </div>

    <!-- FILTROS -->
    <div class="sales-territory-filters">
        <div class="row g-3">

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Desde</label>
                <input class="form-control" type="datetime-local" @bind="FechaDesde" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Hasta</label>
                <input class="form-control" type="datetime-local" @bind="FechaHasta" />
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Filtro</label>
                <select class="form-select" @bind="Filtro">
                    <option value="">Seleccione...</option>
                    <option value="Nombre">Nombre</option>
                    <option value="Grupo">Grupo</option>
                    <option value="Codigo">Código país/región</option>
                </select>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label">Buscar</label>
                <div class="input-group">
                    <input class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
                    
                    <button class="btn btn-primary" @onclick="Filtrar">
                        <i class="bi bi-search"></i>
                    </button>

                    <button class="btn btn-outline-primary" @onclick="Restablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- TABLA -->
    <div class="table-responsive sales-territory-table">

        <QuickGrid Class="table table-hover"
                   Pagination="@pages"
                   Items="ListaSalesTerritory.AsQueryable()"
                   ItemKey="@(e => e.TerritoryId)">

            <PropertyColumn Property="@(s => s.TerritoryId)" Title="ID" />
            <PropertyColumn Property="@(s => s.Name)" Title="Nombre" />
            <PropertyColumn Property="@(s => s.CountryRegionCode)" Title="País/Región" />
            <PropertyColumn Property="@(s => s.Group)" Title="Grupo" />
            <PropertyColumn Property="@(s => s.SalesYtd)" Format="C2" Title="Ventas" />
            <PropertyColumn Property="@(s => s.SalesLastYear)" Format="C2" Title="Ventas LY" />
            <PropertyColumn Property="@(s => s.CostYtd)" Format="C2" Title="Costos" />
            <PropertyColumn Property="@(s => s.CostLastYear)" Format="C2" Title="Costos LY" />

            @if (canEdit)
            {
                <TemplateColumn Class="text-center" Context="s" Title="Acciones">
                    <a href="/SalesTerritory/Edit/@s.TerritoryId"
                           class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Modificar
                    </a>
                </TemplateColumn>
            }
        </QuickGrid>

        <Paginator State="@pages" />

    </div>
</div>

@code {
    public List<SalesTerritory> ListaSalesTerritory { get; set; } = new List<SalesTerritory>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };
    private bool canEdit = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        canEdit = user.IsInRole("Admin");

        ListaSalesTerritory = await salesTerritoryService.GetList(s => s.TerritoryId > 0);
        ListaSalesTerritory = ListaSalesTerritory.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<SalesTerritory, bool>> criterio = s => s.TerritoryId > 0;

        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(s => s.ModifiedDate >= FechaDesde.Value && s.ModifiedDate <= fechaHasta);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(s => s.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHasta = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(s => s.ModifiedDate <= fechaHasta);
        }
        if (Filtro != "" && ValorFiltro != "")
        {
            if (Filtro == "Nombre")
            {
                criterio = criterio.And(s => s.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            if (Filtro == "Grupo")
            {
                criterio = criterio.And(s => s.Group.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            if (Filtro == "Codigo")
            {
                criterio = criterio.And(s => s.CountryRegionCode.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }
        ListaSalesTerritory = await salesTerritoryService.GetList(criterio);
        ListaSalesTerritory = ListaSalesTerritory.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
