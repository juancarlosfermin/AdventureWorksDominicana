@page "/Shipping/Index"
@attribute [Authorize(Roles = "Admin,ShippingManager")]
@rendermode InteractiveServer

@using AdventureWorksDominicana.Data.Models
@inject ShippingService shippingService

<PageTitle>Dashboard de Envíos</PageTitle>

<div class="container mb-5">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard de Envíos
                </h5>
                <small class="text-muted">Monitoreo centralizado de métodos y órdenes</small>
            </div>
            <a href="/Shipping/InTransit/Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-truck"></i> En Tránsito
            </a>
        </div>

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(mensajeError))
            {
                <div class="alert alert-danger">@mensajeError</div>
            }

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border shadow-sm">
                        <div class="card-body">
                            <h6 class="text-muted">
                                <i class="bi bi-send me-1"></i>Métodos Activos
                            </h6>
                            <h3 class="text-dark">@resumen.Count</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border shadow-sm">
                        <div class="card-body">
                            <h6 class="text-muted">
                                <i class="bi bi-cart-check me-1"></i>Órdenes de Venta
                            </h6>
                            <h3 class="text-dark">@resumen.Sum(r => r.TotalVentas)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border shadow-sm">
                        <div class="card-body">
                            <h6 class="text-muted">
                                <i class="bi bi-bag-check me-1"></i>Órdenes de Compra
                            </h6>
                            <h3 class="text-dark">@resumen.Sum(r => r.TotalCompras)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border shadow-sm">
                        <div class="card-body">
                            <h6 class="text-muted">
                                <i class="bi bi-cash-stack me-1"></i>Flete Total
                            </h6>
                            <h3 class="text-dark">@resumen.Sum(r => r.FleteTotal).ToString("C2")</h3>
                        </div>
                    </div>
                </div>
            </div>

            <h6 class="fw-bold mb-3">
                <i class="bi bi-table me-1"></i>Resumen por Método de Envío
            </h6>

            @if (resumen.Any())
            {
                <div class="table-responsive">
                    <QuickGrid TGridItem="ShipMethodResumen"
                               Items="resumen.AsQueryable()"
                               class="table table-hover table-bordered align-middle mb-0">

                        <TemplateColumn Title="Método">
                            <strong>@context.Name</strong>
                        </TemplateColumn>

                        <TemplateColumn Title="Costo Base">
                            <div class="text-end">@context.ShipBase.ToString("C2")</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Tarifa / lb">
                            <div class="text-end">@context.ShipRate.ToString("C2")</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Ventas">
                            <div class="text-center">@context.TotalVentas</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Flete Ventas">
                            <div class="text-end">@context.FleteVentas.ToString("C2")</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Compras">
                            <div class="text-center">@context.TotalCompras</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Flete Compras">
                            <div class="text-end">@context.FleteCompras.ToString("C2")</div>
                        </TemplateColumn>

                        <TemplateColumn Title="Total Órdenes">
                            <div class="text-center">
                                <span class="badge bg-light text-dark border">
                                    @context.TotalOrdenes
                                </span>
                            </div>
                        </TemplateColumn>

                    </QuickGrid>
                </div>
            }

        </div>
    </div>
</div>

@code {
    private List<ShipMethodResumen> resumen = new();
    private string mensajeError = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            resumen = await shippingService.GetResumenPorMetodo();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar el dashboard: {ex.Message}";
        }
    }
}