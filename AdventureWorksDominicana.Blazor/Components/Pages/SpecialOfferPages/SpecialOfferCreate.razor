@page "/SpecialOffer/Create"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.Forms
@inject SpecialOfferService specialOfferService
@inject ToastService toastService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<PageTitle>Crear Oferta Especial</PageTitle>

<EditForm Model="Offer" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container mt-4">
        <div class="card shadow-lg">
            
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Nueva Oferta Especial</h5>
            </div>

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Descripción del Descuento</label>
                        <InputText class="form-control" @bind-Value="Offer.Description" placeholder="Ej: Rebaja de Verano 2026" />
                        <ValidationMessage For="(() => Offer.Description)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">% Descuento (Decimal)</label>
                        <InputNumber class="form-control" step="0.01" @bind-Value="Offer.DiscountPct" />
                        <ValidationMessage For="(() => Offer.DiscountPct)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tipo de Oferta</label>
                        <InputSelect class="form-select" @bind-Value="Offer.Type">
                            <option value="">Seleccione...</option>
                            <option value="Sin Descuento">Sin Descuento</option>
                            <option value="Descuento por Volumen">Descuento por Volumen</option>
                            <option value="Oferta de Temporada">Oferta de Temporada</option>
                            <option value="Producto Descontinuado">Producto Descontinuado</option>
                            <option value="Exceso de Inventario">Exceso de Inventario</option>
                            <option value="Nuevo Producto">Nuevo Producto</option>
                        </InputSelect>
                        <ValidationMessage For="(() => Offer.Type)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Categoría</label>
                        <InputSelect class="form-select" @bind-Value="Offer.Category">
                            <option value="">Seleccione...</option>
                            <option value="Customer">Customer</option>
                            <option value="Pre Seller">Pre Seller</option>
                        </InputSelect>
                        <ValidationMessage For="(() => Offer.Category)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Fecha Inicio</label>
                        <InputDate class="form-control" @bind-Value="Offer.StartDate" />
                        <ValidationMessage For="(() => Offer.StartDate)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Fecha Fin</label>
                        <InputDate class="form-control" @bind-Value="Offer.EndDate" />
                        <ValidationMessage For="(() => Offer.EndDate)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Cantidad Mínima</label>
                        <InputNumber class="form-control" @bind-Value="Offer.MinQty" />
                        <ValidationMessage For="(() => Offer.MinQty)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Cantidad Máxima</label>
                        <InputNumber class="form-control" @bind-Value="Offer.MaxQty" />
                        <ValidationMessage For="(() => Offer.MaxQty)" />
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-center gap-2">
                <a class="btn btn-secondary d-flex align-items-center gap-2" href="/SpecialOffer/Index">
                    <i class="bi bi-arrow-left"></i>
                    <span>Volver</span>
                </a>
                <button class="btn btn-primary d-flex align-items-center gap-2" type="submit">
                    <i class="bi bi-floppy"></i>
                    <span>Guardar</span>
                </button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public SpecialOffer Offer { get; set; } = new SpecialOffer
    {
        StartDate = DateTime.Now,
        EndDate = DateTime.Now.AddMonths(1),
        MinQty = 0,
        ModifiedDate = DateTime.Now,
        Rowguid = Guid.NewGuid()
    };

    public async Task Guardar()
    {
        if (await specialOfferService.Guardar(Offer))
        {
            toastService.ShowSuccess("Oferta creada correctamente.");
            navigationManager.NavigateTo("/SpecialOffer/Index");
        }
        else
        {
            toastService.ShowError("Error al guardar la oferta.");
        }
    }
}