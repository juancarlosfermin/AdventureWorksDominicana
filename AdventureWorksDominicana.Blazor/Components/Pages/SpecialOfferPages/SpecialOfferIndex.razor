@page "/SpecialOffer/Index"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@rendermode InteractiveServer
@inject SpecialOfferService specialOfferService

<PageTitle>Ofertas Especiales</PageTitle>

<div class="container mt-4">
    <div class="card shadow-lg">
        
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Ofertas Especiales</h5>
            <a href="SpecialOffer/Create" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="bi bi-plus-square"></i>
                <span>Crear</span>
            </a>
        </div>
        
        <div class="card-body">
            
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Desde</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Hasta</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Filtro:</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Buscar:</label>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-3">
                    <input class="form-control" type="date" @bind="StartDate" />
                </div>
                <div class="col-md-3">
                    <input class="form-control" type="date" @bind="EndDate" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="">Seleccione una opcion</option>
                        <option value="Descripcion">Descripción</option>
                        <option value="Tipo">Tipo de Oferta</option>
                        <option value="Categoria">Categoría</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <input class="form-control" type="text" placeholder="Buscar..." @bind="ValorFiltro" />
                        <button class="btn btn-primary" type="button" @onclick="Buscar" title="Buscar">
                            <i class="bi bi-search"></i>
                        </button>
                        <button class="btn btn-outline-primary" type="button" @onclick="Restablecer" title="Limpiar Filtros">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="table-responsive">
                <QuickGrid Items="OffersList.AsQueryable()" Pagination="@pages" Class="table table-striped table-bordered table-hover">
                    <PropertyColumn Property="@(s => s.Description)" Title="Descripción" Sortable="true" />
                    <PropertyColumn Property="@(s => s.Type)" Title="Tipo" Sortable="true" />
                    <PropertyColumn Property="@(s => s.Category)" Title="Categoría" Sortable="true" />
                    
                    <TemplateColumn Title="Descuento" Sortable="true">
                        @((context.DiscountPct * 100).ToString("N0")) %
                    </TemplateColumn>
                    
                    <PropertyColumn Property="@(s => s.StartDate)" Title="Inicio" Format="dd/MM/yyyy" Sortable="true" />
                    <PropertyColumn Property="@(s => s.EndDate)" Title="Fin" Format="dd/MM/yyyy" Sortable="true" />
                    
                    <TemplateColumn Title="Estado" Align="Align.Center">
                        @if (context.EndDate >= DateTime.Now && context.StartDate <= DateTime.Now)
                        {
                            <span class="badge bg-success">Vigente</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactiva</span>
                        }
                    </TemplateColumn>

                    <TemplateColumn Title="Opciones" Align="Align.Center">
                        <div class="d-flex justify-content-center gap-2">
                            <a href="SpecialOffer/Edit/@context.SpecialOfferId" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-2" title="Modificar">
                                <i class="bi bi-pencil"></i>
                                <span>Modificar</span>
                            </a>
                        </div>
                    </TemplateColumn>
                </QuickGrid>
                
                <Paginator State="@pages" />
            </div>
        </div>

        <div class="card-footer text-end">
            <strong>Total Registros: @OffersList.Count</strong>
        </div>

    </div>
</div>

@code {
    private List<SpecialOffer> OffersList = new List<SpecialOffer>();
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };
    private string Filtro = string.Empty;
    private string ValorFiltro = string.Empty;
    private DateTime? StartDate = null;
    private DateTime? EndDate = null;

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    private async Task Buscar()
    {
        OffersList = await specialOfferService.GetList(s =>
            (!(StartDate.HasValue && EndDate.HasValue) ||
            (s.StartDate >= StartDate.Value.Date && s.StartDate <= EndDate.Value.Date.AddDays(1).AddTicks(-1)))
            &&
            (string.IsNullOrWhiteSpace(ValorFiltro) || string.IsNullOrWhiteSpace(Filtro) ||
                (Filtro == "Descripcion" && s.Description.Contains(ValorFiltro)) ||
                (Filtro == "Tipo" && s.Type.Contains(ValorFiltro)) ||
                (Filtro == "Categoria" && s.Category.Contains(ValorFiltro))
            )
        );
    }

    private async Task Restablecer()
    {
        StartDate = null;
        EndDate = null;
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
        await Buscar();
    }
}