@page "/StateProvince/Create"

@inject StateProvinceService stateProvinceService;
@inject CountryRegionsService countryRegionsService;
@inject SalesTerritoryService salesTerritoryService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<EditForm Model="StateProvince" FormName="crearStateProvince" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card">
            <div class="card-header text-center">
                <h4>Crear StateProvince</h4>
            </div>
            <div class="card-body">
                @* Nombre *@
                <div class="mb-3">
                    <label class="form-label"><strong>Nombre</strong></label>
                    <input class="form-control" type="text" maxlength="50" @bind-value="StateProvince.Name" placeholder="Escriba el nombre..." />
                    <ValidationMessage For="(() => StateProvince.Name)" />
                </div>

                @* StateProvince Code *@
                <div class="mb-3">
                    <label class="form-label"><strong>C&oacute;digo de Estado/Provincia</strong></label>
                    <input class="form-control" type="text" maxlength="3" @bind="StateProvince.StateProvinceCode" @bind:after="ConvertirMayuscula" placeholder="Escriba el codigo..." />
                    <ValidationMessage For="(() => StateProvince.StateProvinceCode)" />
                </div>

                @* CountryRegion Code *@
                <div class="mb-3">
                    <label class="form-label"><strong>C&oacute;digo de pa&iacute;s/regi&oacute;n</strong></label>
                    <select class="form-select" @bind="@StateProvince.CountryRegionCode" @bind:after="CargarSalesTerritories">
                        <option value="" disabled hidden selected>Seleccione un pa&iacute;s/regi&oacute;n...</option>
                        @foreach (var countryRegion in ListaCountryRegion)
                        {
                            <option value="@countryRegion.CountryRegionCode">@countryRegion.Name (@countryRegion.CountryRegionCode)</option>
                        }
                    </select>
                    <ValidationMessage For="(() => StateProvince.CountryRegionCode)" />
                </div>

                @* Sales Territory *@
                <div class="mb-3">
                    <label class="form-label"><strong>Territorio de Ventas</strong></label>
                    <select class="form-select" @bind="@StateProvince.TerritoryId">
                        @if (string.IsNullOrEmpty(StateProvince.CountryRegionCode))
                        {
                            <option value="0" disabled selected hidden>Primero seleccione un país</option>
                        }
                        else if (!ListaSalesTerritory.Any())
                        {
                            <option value="0" disabled selected hidden>
                                No hay territorios disponibles para @ObtenerNombrePais(StateProvince.CountryRegionCode)
                            </option>
                        }
                        else
                        {
                            <option value="0" disabled selected hidden>Seleccione un territorio...</option>
                            @foreach (var territory in ListaSalesTerritory)
                            {
                                <option value="@territory.TerritoryId">@territory.Name</option>
                            }
                        }
                    </select>
                    <ValidationMessage For="(() => StateProvince.TerritoryId)" />
                </div>
            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/StateProvince/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public StateProvince StateProvince { get; set; } = new StateProvince();
    public List<CountryRegion> ListaCountryRegion { get; set; } = new List<CountryRegion>();
    public List<SalesTerritory> ListaSalesTerritory { get; set; } = new List<SalesTerritory>();

    protected override async Task OnInitializedAsync()
    {
        ListaCountryRegion = await countryRegionsService.GetList(c => !c.CountryRegionCode.Equals(""));
        ListaCountryRegion = ListaCountryRegion.OrderBy(c => c.Name).ToList();
    }

    public async Task Guardar()
    {
        bool repetido = await stateProvinceService.BuscarRepetido(StateProvince.StateProvinceCode, StateProvince.StateProvinceId, StateProvince.CountryRegionCode);
        if (repetido)
        {
            toastService.ShowWarning("El codigo \"" + StateProvince.StateProvinceCode + "\" ya esta en uso.");
            return;
        }

        if (StateProvince.TerritoryId <= 0)
        {
            toastService.ShowWarning("Debe seleccionar un territorio de ventas.");
            return;
        }

        bool territorioValido = ListaSalesTerritory.Any(t => t.TerritoryId == StateProvince.TerritoryId);
        if (!territorioValido)
        {
            toastService.ShowWarning("El territorio seleccionado no es válido para este país.");
            return;
        }

        StateProvince.ModifiedDate = DateTime.Now;
        bool guardado = await stateProvinceService.Guardar(StateProvince);
        if (guardado)
        {
            toastService.ShowSuccess("El Estado/Provincia se ha guardado correctamente.");
            navigationManager.NavigateTo("/StateProvince/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar el estado/provincia.");
        }
    }

    private string ObtenerNombrePais(string countryCode)
    {
        var pais = ListaCountryRegion.FirstOrDefault(c => c.CountryRegionCode == countryCode);
        return pais?.Name ?? countryCode;
    }

    public async Task CargarSalesTerritories()
    {
        StateProvince.TerritoryId = 0;

        // Cargar territorios del país seleccionado
        if (!string.IsNullOrEmpty(StateProvince.CountryRegionCode))
        {
            ListaSalesTerritory = await salesTerritoryService.GetList(s => s.CountryRegionCode == StateProvince.CountryRegionCode);
            ListaSalesTerritory = ListaSalesTerritory.OrderBy(t => t.Name).ToList();
        }
        else
        {
            ListaSalesTerritory = new List<SalesTerritory>();
        }
    }

    public async Task ConvertirMayuscula()
    {
        StateProvince.StateProvinceCode = StateProvince.StateProvinceCode.ToUpper();
    }
}
