@page "/Store/Index"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@inject NavigationManager navigationManager
@inject StoreService storeService
@rendermode InteractiveServer

<PageTitle>Store</PageTitle>

<div class="container-fluid">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-content-center">
            <h3 class="mb-0">Store</h3>
            <a class="btn btn-primary" href="/Store/Create"><i class="bi bi-plus-square"></i> Crear</a>
        </div>

        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label">Desde</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hasta</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filtro</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Buscar</label>
                </div>
            </div>
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-md-3">
                    <InputDate class="form-control" @bind-Value="Desde" />
                </div>
                <div class="col-md-3">
                    <InputDate class="form-control" @bind-Value="Hasta" />
                </div>
                <div class="col-md-3">
                    <InputSelect class="form-select" @bind-Value="Filtros">
                        <option disabled value="">Elige un filtro</option>
                        <option value="Id">ID</option>
                        <option value="Name">Nombre</option>
                        <option value="SalesPerson">Sales Person ID</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <div class="d-flex">
                        <InputText class="form-control me-2" @bind-Value="ValorFiltro" placeholder="Buscar..." />
                        <button class="btn btn-primary me-2" @onclick="Buscar">
                            <i class="bi bi-search"></i>
                        </button>
                        <button type="button" class="btn btn-outline-primary bi bi-arrow-counterclockwise" @onclick="Restablecer"></button>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <QuickGrid TGridItem="Store" Items="ListaStores" Class="table table-striped table-bordered table-hover">
                    <PropertyColumn Property="@(e => e.BusinessEntityId)" Sortable="true" Title="ID" />
                    <PropertyColumn Property="@(e => e.Name)" Sortable="true" Title="Nombre" />
                    <PropertyColumn Property="@(e => e.SalesPersonId)" Sortable="true" Title="SalesPersonId" />
                    <PropertyColumn Property="@(e => e.ModifiedDate)" Format="dd/MM/yyyy" Title="Fecha de modificación" Sortable="true" />

                    <TemplateColumn Class="text-center align-middle" Title="Acción">
                        <a class="btn btn-outline-primary btn-sm" href="/Store/Edit/@context.BusinessEntityId">
                            <i class="bi bi-pencil-square"></i> Modificar
                        </a>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        </div>

        <div class="card-footer text-end">
            <strong>Conteo Registros: </strong> @ListaStores.Count()
        </div>
    </div>
</div>

@code {
    public IQueryable<Store> ListaStores { get; set; } = Enumerable.Empty<Store>().AsQueryable();
    public string Filtros { get; set; } = string.Empty;
    public string ValorFiltro { get; set; } = string.Empty;
    public DateTime? Desde { get; set; }
    public DateTime? Hasta { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    public async Task Buscar()
    {
        List<Store> resultado;

        if (!string.IsNullOrWhiteSpace(ValorFiltro))
        {
            if (Filtros == "Id" && int.TryParse(ValorFiltro, out int id))
            {
                resultado = await storeService.GetList(x => x.BusinessEntityId == id);
            }
            else if (Filtros == "Name")
            {
                resultado = await storeService.GetList(x => x.Name.ToLower().Contains(ValorFiltro.ToLower()));
            }
            else if (Filtros == "SalesPerson" && int.TryParse(ValorFiltro, out int spId))
            {
                resultado = await storeService.GetList(x => x.SalesPersonId.HasValue && x.SalesPersonId.Value == spId);
            }
            else
            {
                resultado = await storeService.GetList(x => true);
            }
        }
        else
        {
            resultado = await storeService.GetList(x => true);
        }

        if (Desde.HasValue)
            resultado = resultado.Where(x => x.ModifiedDate >= Desde.Value).ToList();

        if (Hasta.HasValue)
            resultado = resultado.Where(x => x.ModifiedDate <= Hasta.Value).ToList();

        ListaStores = resultado.AsQueryable();
    }

    private async Task Restablecer()
    {
        Desde = null;
        Hasta = null;
        ValorFiltro = string.Empty;
        Filtros = string.Empty;
        await Buscar();
    }
}
