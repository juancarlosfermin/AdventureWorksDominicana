@page "/TransactionHistory/Edit/{Id:int}"
@inject TransactionHistoryService transactionHistoryService
@inject ProductService productService 
@inject NavigationManager navigationManager
@inject ToastService toastService

@rendermode InteractiveServer

<PageTitle>Editar Historial de Transacci&oacute;n</PageTitle>

@if (transaccion == null)
{
    <div class="container mt-4"><p>Cargando informaci&oacute;n...</p></div>
}
else
{
    <EditForm Model="transaccion" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />

        <div class="container mt-4">
            <div class="card shadow-lg">

                <div class="card-header bg-white">
                    <h4 class="mb-0">Modificar Historial de Transacci&oacute;n</h4>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <strong>ID Transacci&oacute;n</strong>
                        <InputNumber class="form-control" @bind-Value="transaccion.TransactionId" readonly />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Producto</strong>
                            <InputSelect class="form-select" @bind-Value="transaccion.ProductId">
                                <option value="" disabled selected>Seleccione un producto...</option>
                                @foreach (var producto in listaProductos)
                                {
                                    <option value="@producto.ProductId">@producto.ProductId - @producto.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => transaccion.ProductId" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Fecha de Transacci&oacute;n</strong>
                            <InputDate class="form-control" @bind-Value="transaccion.TransactionDate" />
                            <ValidationMessage For="() => transaccion.TransactionDate" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Tipo de Transacci&oacute;n</strong>
                            <InputSelect class="form-select" @bind-Value="transaccion.TransactionType">
                                <option value="" disabled selected>Seleccione un tipo...</option>
                                <option value="W">Work Order (W)</option>
                                <option value="S">Sales Order (S)</option>
                                <option value="P">Purchase Order (P)</option>
                            </InputSelect>
                            <ValidationMessage For="() => transaccion.TransactionType" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Cantidad</strong>
                            <InputNumber class="form-control" @bind-Value="transaccion.Quantity" />
                            <ValidationMessage For="() => transaccion.Quantity" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <strong>ID Orden de Referencia</strong>
                            <InputNumber class="form-control" @bind-Value="transaccion.ReferenceOrderId" />
                            <ValidationMessage For="() => transaccion.ReferenceOrderId" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <strong>L&iacute;nea de Orden</strong>
                            <InputNumber class="form-control" @bind-Value="transaccion.ReferenceOrderLineId" />
                            <ValidationMessage For="() => transaccion.ReferenceOrderLineId" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <strong>Costo Real</strong>
                            <InputNumber class="form-control" @bind-Value="transaccion.ActualCost" />
                            <ValidationMessage For="() => transaccion.ActualCost" />
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensajeError))
                    {
                        <div class="alert alert-danger mt-3">@mensajeError</div>
                    }

                </div>

                <div class="card-footer text-center bg-white">
                    <a href="/TransactionHistory/Index" class="btn btn-secondary bi bi-arrow-left"> Volver</a>
                    <button type="submit" class="btn btn-primary bi bi-floppy"> Modificar</button>
                    <button type="button" class="btn btn-danger bi bi-trash" @onclick="() => mostrarModal = true"> Eliminar</button>
                </div>
            </div>
        </div>
    </EditForm>

    @if (mostrarModal)
    {
        <div class="container mt-3">
            <div class="alert alert-danger shadow-sm">
                <p class="fw-bold">¿Desea eliminar este registro?</p>
                <button class="btn btn-secondary me-2" @onclick="() => mostrarModal = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="EliminarConfirmado">S&iacute;, eliminar definitivamente</button>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private TransactionHistory? transaccion;
    private List<Product> listaProductos = new();
    private string mensajeError = string.Empty;
    private bool mostrarModal = false;

    protected override async Task OnParametersSetAsync()
    {
        transaccion = await transactionHistoryService.Buscar(Id);
        
        if (transaccion == null)
        {
            mensajeError = "No se encontró el historial de transacción.";
        }
        else
        {
            listaProductos = await productService.GetList(p => true);
        }
    }

    private async Task Guardar()
    {
        if (transaccion == null) return;
        
        transaccion.ModifiedDate = DateTime.Now;
        mensajeError = string.Empty;

        try
        {
            if (await transactionHistoryService.Guardar(transaccion))
            {
                toastService.ShowSuccess("Cambios guardados correctamente.");
                navigationManager.NavigateTo("/TransactionHistory/Index");
            }
        }
        catch (Exception ex)
        {
            string errorReal = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            mensajeError = $"Error al actualizar. Detalle: {errorReal}";
        }
    }

    private async Task EliminarConfirmado()
    {
        if (transaccion == null) return;

        if (await transactionHistoryService.Eliminar(transaccion.TransactionId))
        {
            toastService.ShowSuccess("Registro eliminado correctamente.");
            navigationManager.NavigateTo("/TransactionHistory/Index");
        }
        else
        {
            mensajeError = "No se pudo eliminar el registro.";
            mostrarModal = false;
        }
    }
}