@page "/UnitMeasure/Create"

@inject UnitMeasureService unitMeasureService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<EditForm Model="UnitMeasure" FormName="crearUnitMeasure" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card shadow-lg">
            <div class="card-header text-center">
                <h4>Crear Unidad de Medida</h4>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label><strong>C&oacute;digo (Máx 3 Caracteres)</strong></label>
                    <input class="form-control" type="text" maxlength="3" @bind="UnitMeasure.UnitMeasureCode" placeholder="Ej: LBS, KG, CM..." />
                    <ValidationMessage For="(() => UnitMeasure.UnitMeasureCode)" />
                </div>

                <div class="mb-3">
                    <label><strong>Nombre descriptivo</strong></label>
                    <input class="form-control" type="text" maxlength="50" @bind="UnitMeasure.Name" placeholder="Ej: Libras" />
                    <ValidationMessage For="(() => UnitMeasure.Name)" />
                </div>
            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/UnitMeasure/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public UnitMeasure UnitMeasure { get; set; } = new UnitMeasure();

    public async Task Guardar()
    {
        if (await unitMeasureService.Existe(UnitMeasure.UnitMeasureCode))
        {
            toastService.ShowWarning("Este código de unidad ya existe.");
            return;
        }

        bool guardado = await unitMeasureService.Guardar(UnitMeasure);
        if (guardado)
        {
            toastService.ShowSuccess("Unidad guardada correctamente.");
            navigationManager.NavigateTo("/UnitMeasure/Index");
        }
        else
        {
            toastService.ShowError("Error al guardar la unidad.");
        }
    }
}
