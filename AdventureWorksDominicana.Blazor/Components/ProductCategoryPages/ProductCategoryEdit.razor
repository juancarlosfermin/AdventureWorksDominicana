@page "/ProductCategory/Edit/{Id:int}"
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductCategoryService categoryService

@rendermode InteractiveServer

<PageTitle>Editar Categor&iacute;a</PageTitle>

<Toasts class="p-3" AutoHide="true" Delay="5000" Placement="ToastsPlacement.TopRight" />

@if (categoria == null)
{
    <div class="container mt-4">
        <p><em>Cargando categor&iacute;a...</em></p>
    </div>
}
else
{
    <EditForm Model="categoria" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />

        <div class="container mt-4">
            <div class="card shadow-lg">

                <div class="card-header">
                    <h4 class="mb-0">Editar Categor&iacute;a de Producto</h4>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-bold">ID Categor&iacute;a</label>
                        <InputNumber class="form-control" @bind-Value="categoria.ProductCategoryId" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre de Categor&iacute;a</label>
                        <InputText class="form-control" @bind-Value="categoria.Name" />
                        <ValidationMessage For="() => categoria.Name" />
                    </div>

                    <div class="border border-success p-3 mb-3">
                        <h3 class="mb-3">Detalle de Subcategor&iacute;as</h3>

                        <div class="row mb-3 align-items-end">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Nombre de la Subcategor&iacute;a</label>
                                <InputText class="form-control" @bind-Value="NuevaSubcategoriaNombre" placeholder="Nombre de la subcategor&iacute;a..." />
                            </div>

                            <div class="col-md-2">
                                <button type="button" class="btn btn-primary bi bi-plus" @onclick="AgregarDetalle">
                                    Agregar
                                </button>
                            </div>
                        </div>

                        <QuickGrid Items="categoria.ProductSubcategories.AsQueryable()" Class="table table-striped table-bordered">
                            <PropertyColumn Property="@(d => d.Name)" Title="Nombre Subcategor&iacute;a" />
                            <TemplateColumn Title="Acci&oacute;n">
                                <ChildContent Context="det">
                                    <button type="button" class="btn btn-outline-danger btn-sm bi bi-trash" @onclick="(() => RemoverDetalle(det))">
                                        Eliminar
                                    </button>
                                </ChildContent>
                            </TemplateColumn>
                        </QuickGrid>
                    </div>

                    <div class="mt-3 fw-bold">
                        Total Subcategor&iacute;as: @categoria.ProductSubcategories.Count
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensaje))
                    {
                        <div class="alert alert-danger mt-2">
                            @mensaje
                        </div>
                    }

                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-outline-secondary bi bi-arrow-left" href="/ProductCategory/Index"> Volver</a>
                    <button type="submit" class="btn btn-outline-success bi bi-file-earmark"> Guardar Cambios</button>
                    <button type="button" class="btn btn-outline-danger bi bi-trash" @onclick="() => mostrarModal = true"> Eliminar Categoría</button>
                </div>

            </div>
        </div>
    </EditForm>

    @if (mostrarModal)
    {
        <div class="container mt-3">
            <div class="alert alert-danger shadow-sm">
                <p class="fw-bold">¿Desea eliminar esta categor&iacute;a y todas sus subcategor&iacute;as?</p>
                <button class="btn btn-secondary me-2" @onclick="() => mostrarModal = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="EliminarConfirmado">Si, eliminar definitivamente</button>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private ProductCategory? categoria;
    private string NuevaSubcategoriaNombre = string.Empty;
    private string mensaje = string.Empty;
    private bool mostrarModal = false;

    protected override async Task OnParametersSetAsync()
    {
        categoria = await categoryService.Buscar(Id);

        if (categoria == null)
        {
            mensaje = "La categoría no existe.";
        }
    }

    private void AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(NuevaSubcategoriaNombre))
        {
            mensaje = "El nombre de la subcategoría es obligatorio.";
            return;
        }

        categoria!.ProductSubcategories.Add(new ProductSubcategory
        {
            Name = NuevaSubcategoriaNombre,
            ModifiedDate = DateTime.Now,
            Rowguid = Guid.NewGuid(),
            ProductCategoryId = categoria.ProductCategoryId
        });

        NuevaSubcategoriaNombre = string.Empty;
        mensaje = string.Empty;
        toastService.ShowSuccess("Subcategoría agregada a la lista.");
    }

    private void RemoverDetalle(ProductSubcategory det)
    {
        NuevaSubcategoriaNombre = det.Name;

        categoria!.ProductSubcategories.Remove(det);
        toastService.ShowWarning("Detalle removido de la lista.");
    }

    private async Task Guardar()
    {
        if (categoria == null) return;

        if (!categoria.ProductSubcategories.Any())
        {
            mensaje = "Debe haber al menos una subcategoría.";
            return;
        }

        categoria.ModifiedDate = DateTime.Now;

        try
        {
            if (await categoryService.Guardar(categoria))
            {
                toastService.ShowSuccess("Cambios guardados correctamente.");
                navigationManager.NavigateTo("/ProductCategory/Index");
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error al guardar: " + ex.Message;
        }
    }

    private async Task EliminarConfirmado()
    {
        if (categoria == null) return;

        if (await categoryService.Eliminar(categoria.ProductCategoryId))
        {
            toastService.ShowSuccess("Categoría eliminada.");
            navigationManager.NavigateTo("/ProductCategory/Index");
        }
        else
        {
            mensaje = "No se pudo eliminar la categoría.";
            mostrarModal = false;
        }
    }
}